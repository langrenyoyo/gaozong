# auto_wechat 环境变量模板
# 使用方式：复制为 .env，并只在 .env 中填写真实密钥。
# 注意：.env 包含密钥，已被 .gitignore 排除，禁止提交真实配置。

# ---------- 9000 数据库 ----------
# 默认仍使用 SQLite：data/auto_wechat.db。
# P2-A 已支持 DATABASE_URL 配置抽象；PostgreSQL 后续由 Docker Compose 容器提供，本轮不启用。
# DATABASE_URL=sqlite:///./data/auto_wechat.db
# P2-D 可选 PostgreSQL dev profile 示例；默认不要取消注释，后续切换任务再启用。
# DATABASE_URL=postgresql+asyncpg://auto_wechat:change_me@postgres:5432/auto_wechat
# P2-E 连接池预留配置；当前只读取配置，不创建 pool。QPS600 生产值必须压测后确定，不要直接照搬默认值。
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# DB_STATEMENT_TIMEOUT_MS=5000

# ---------- douyinAPI 上游线索同步 ----------
# 9000 从历史上游 douyinAPI 拉取线索时使用。当前正式 webhook 已由 9000 直收，旧同步链路仍保留。
# 本地开发默认指向本机 8081；部署到容器或远端时填可被 9000 访问的 HTTP 地址。
DOUYIN_API_BASE_URL=http://127.0.0.1:8081
# 9000 调用 douyinAPI 的请求超时时间，单位：秒。
DOUYIN_API_TIMEOUT_SECONDS=10
# 手动/定时同步线索时的默认拉取数量上限。
DOUYIN_SYNC_DEFAULT_LIMIT=50

# ---------- 抖音 GMP / OpenAPI 直连接入 ----------
# 运行环境。production 会强制 webhook 验签，即使 DOUYIN_WEBHOOK_AUTH_REQUIRED=false 也不会放行。
APP_ENV=development
# 抖音 webhook 验签密钥，用于 9000 正式 webhook 入站验签；生产必须配置真实值。
DY_SECRET_KEY=
# 抖音 OpenAPI 请求签名密钥，用于扫码授权、私信会话、图片上传等 GMP OpenAPI 调用。
DY_GMP_SECRET_KEY=
# 抖音 OpenAPI 域名和路径前缀。正式环境通常保持默认值；测试环境只替换 prefix。
DY_OPENAPI_BASE_URL=https://gmp.bytedanceapi.com
# 测试环境前缀（正式环境改为 /ai_chat_agent_api/v1/openapi）
DY_OPENAPI_PREFIX=/ai_chat_agent_api/v1/openapi
# 测试环境示例：
# DY_OPENAPI_PREFIX=/ai_chat_agent_test_api/v1/openapi
# 旧版完整 base url 降级变量，仅用于兼容历史配置；新部署不要优先使用。
# DY_BASE_URL=
# 主账户 ID 和展示名，用于抖音授权、账号绑定、资源下载和发送服务的主账号上下文。
DY_MAIN_ACCOUNT_ID=0
DY_ACCOUNT_NAME=
# 9000 调用抖音 OpenAPI 的请求超时时间，单位：秒。
DY_HTTP_TIMEOUT_SECONDS=20
# live-check 资源下载可信域名白名单，逗号分隔；留空时仅拦截非 http(s)、localhost、私网和 metadata 地址。
# 生产确认抖音资源域名后建议显式配置，例如：api-normal.amemv.com。
DOUYIN_RESOURCE_ALLOWED_HOSTS=
# webhook 时间戳允许漂移，单位：秒；超过该窗口会拒绝请求。
DY_ALLOWED_DRIFT_SECONDS=300
# 当前 9000 对外可访问地址，用于部分回跳地址兜底；不要填 compose 内部 service name。
PUBLIC_BASE_URL=https://callback.misanduo.com
# 传给抖音后台的 OAuth 回调地址，必须是 9000 后端可接收授权 code 的公网地址。
DY_AUTH_REDIRECT_URL=https://callback.misanduo.com/integrations/douyin/live-check/oauth-callback
# 授权完成后 9000 再跳回前端的地址；公网部署时填浏览器可访问的前端地址。
DY_AUTH_REDIRECT_FRONTEND_URL=
# 抖音 OAuth 授权完成后允许跳回的前端 origin 白名单，逗号分隔。
# 生产环境必须显式配置；development 如需 localhost / 局域网地址，也必须显式加入。
# 示例：DY_AUTH_REDIRECT_ALLOWED_ORIGINS=https://douyinapi.misanduo.com,http://127.0.0.1:5173,http://192.168.110.113:5173
DY_AUTH_REDIRECT_ALLOWED_ORIGINS=
# 抖音 OAuth state 有效期，单位秒。默认 15 分钟，过期或已消费 state 不允许绑定企业号。
DY_OAUTH_STATE_TTL_SECONDS=900
# 抖音事件回调地址。现场观察模式通常指向 webhook-observe；正式 webhook 请按部署方案配置。
DY_CALLBACK_URL=https://callback.misanduo.com/integrations/douyin/live-check/webhook-observe
# 向抖音订阅的回调事件，多个值用英文逗号分隔。
DY_CALLBACK_EVENTS=im_receive_msg,im_send_msg,im_enter_direct_msg
# 入站 webhook 是否强制验签。development 可设 false 便于本地联调；production 始终强制验签。
# 生产建议：APP_ENV=production、DOUYIN_WEBHOOK_AUTH_REQUIRED=true、DY_SECRET_KEY=<真实密钥>。
DOUYIN_WEBHOOK_AUTH_REQUIRED=false

# ---------- NewCarProject 登录鉴权 ----------
# 是否启用真实 NewCarProject 登录态校验。生产商户端接口应设为 true。
NEWCAR_AUTH_ENABLED=false
# 本地开发 mock 开关。真实联调/生产必须设为 false，避免绕过 NewCarProject。
NEWCAR_AUTH_MOCK_ENABLED=true
# NewCarProject 外部认证服务根地址；9000 会拼接 /api/external-auth/exchange-code 和 /api/external-auth/me。
# 按当前对接文档，真实协议不存在 introspect；code 登录先 exchange-code 换 token，再用 token 调 external-auth/me。
NEWCAR_AUTH_BASE_URL=http://127.0.0.1:8790
# 如网关或部署环境需要分别指定完整地址，可覆盖上面的根地址拼接规则；一般留空即可。
NEWCAR_AUTH_EXCHANGE_CODE_URL=
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://192.168.110.113:5173,http://192.168.110.113:9000,http://192.168.110.19:5174
NEWCAR_AUTH_ME_URL=
NEWCAR_AUTH_LOGOUT_URL=
# 前端收到 401/登录失效后可跳转的 NewCarProject 登录地址，供接口和联调文档使用。
NEWCAR_AUTH_LOGIN_URL=
# 9000 调用 NewCarProject 外部认证接口的服务令牌；如配置，当前代码使用 X-NewCar-Service-Token 请求头。
# 当前同事文档未要求该 header；仅在 NewCarProject 侧明确启用服务间鉴权时填写。
NEWCAR_AUTH_SERVICE_TOKEN=
# 调用 NewCarProject exchange-code / external-auth/me 的超时时间，单位：秒。
NEWCAR_AUTH_TIMEOUT_SECONDS=5

# ---------- 前端直连 NewCarProject 一次性 code 换 token ----------
# 浏览器收到 ?code=xxx&source=new_car_project 后会直连该地址的 /api/external-auth/exchange-code。
VITE_NEWCAR_AUTH_BASE_URL=http://192.168.110.19:8790
VITE_NEWCAR_LOGIN_URL=http://192.168.110.19:5174/login

# ---------- 9000 调用 9100 抖音AI小高客服可信代理 ----------
# 浏览器后续应优先调用 9000，由 9000 注入可信 merchant_id 后再转发到 9100。
# 本机直启可用 http://localhost:9100；Docker compose 内 9000 调 9100 必须使用 service name。
# XG_DOUYIN_AI_CS_BASE_URL=http://xg-douyin-ai-cs:9100
XG_DOUYIN_AI_CS_BASE_URL=http://xg-douyin-ai-cs:9100
# 9000 调用 9100 时附带的内部服务令牌；9100 内部接口使用 X-Internal-Service-Token 校验。
# 生产环境必须配置非空值，并同时注入 9000 和 9100；不要配置为任何 VITE_*，不要暴露给浏览器。
XG_DOUYIN_AI_CS_SERVICE_TOKEN=
# 9000 调用 9100 的请求超时时间，单位：秒。
XG_DOUYIN_AI_CS_TIMEOUT_SECONDS=60

# ---------- 小高知识库内部训练接口 ----------
# 仅用于管理员/内部人员训练统一“小高知识库”，不是商户自建知识库能力。
# ask / feedback 接口不走 NewCarProject 登录态，改用调用方 IP 白名单准入。
# 白名单支持单个 IP、localhost 和 CIDR，多个值用英文逗号分隔；默认只允许本机开发调用。
# 生产环境必须显式替换为真实管理员入口或可信反代来源，不能沿用下面的本机开发默认值。
KNOWLEDGE_TRAINING_IP_WHITELIST=127.0.0.1,::1,localhost
# 统一知识库训练代理的服务间 token，多个值用英文逗号分隔；默认空值表示关闭 token 放行。
# 本地 synthetic smoke 可临时使用 dev_knowledge_training_token，严禁写入真实密钥。
KNOWLEDGE_TRAINING_INTERNAL_TOKENS=
# 训练数据固定归属到统一系统级租户，部署时通常不要修改。
KNOWLEDGE_TRAINING_DEFAULT_TENANT_ID=xiaogao_system
# 训练数据固定归属到统一系统级知识库商户标识，部署时通常不要修改。
KNOWLEDGE_TRAINING_DEFAULT_MERCHANT_ID=xiaogao_base
# 默认不信任 X-Forwarded-For / X-Real-IP，避免客户端伪造来源 IP。
# 只有服务部署在可信反向代理后，并且代理会覆盖这些请求头时，才可设为 true。
KNOWLEDGE_TRAINING_TRUST_PROXY_HEADERS=false

# ---------- 抖音 AI 客服真实自动回复门禁 ----------
# 全局托管自动回复总开关。默认 false，保持只生成建议/记录，不自动发送。
DOUYIN_AUTO_REPLY_ENABLED=false
# 真实发送总开关。必须与 DOUYIN_AUTO_REPLY_ENABLED 同时为 true，且命中白名单和账号配置后才可能发送。
DOUYIN_AUTO_REPLY_REAL_SEND_ENABLED=false
# 是否允许跳过全局白名单进入全量放开模式。生产严禁随意开启，必须经过单独评审。
DOUYIN_AUTO_REPLY_ALLOW_FULL_ROLLOUT=false
# 全局允许自动回复的抖音企业号 open_id 白名单，多个值用英文逗号分隔。
DOUYIN_AUTO_REPLY_ACCOUNT_WHITELIST=
# 全局允许自动回复的客户 open_id 白名单；非全量模式下需命中客户或会话白名单之一。
DOUYIN_AUTO_REPLY_CUSTOMER_WHITELIST=
# 全局允许自动回复的会话 short_id 白名单；非全量模式下需命中客户或会话白名单之一。
DOUYIN_AUTO_REPLY_CONVERSATION_WHITELIST=

# ---------- 9100 算力消耗上报到 9000 ----------
# 9100 LLM chat 成功后可上报 token 消耗到 9000 /internal/compute/usage。
# 未配置 AUTO_WECHAT_9000_BASE_URL 或 COMPUTE_INTERNAL_TOKEN 时，9100 会跳过上报，不影响回复建议主流程。
# Docker compose 内建议：AUTO_WECHAT_9000_BASE_URL=http://auto-wechat-api:9000
AUTO_WECHAT_9000_BASE_URL=
# 9100 上报算力消耗给 9000 的内部令牌；9000 使用 X-Internal-Token 校验。
COMPUTE_INTERNAL_TOKEN=
# 9100 上报算力消耗的请求超时时间，单位：秒。
COMPUTE_USAGE_TIMEOUT_SECONDS=20

# ---------- 抖音现场联调观察工具 ----------
# 默认关闭；仅现场扫码授权 / 真实回调观察时临时开启。
# 只生成授权 URL、记录 callback 摘要和 webhook 请求形状，不换 token、不调用抖音接口。
DY_LIVE_CHECK_ENABLED=false
# 仅用于临时现场调试。开启后，live-check webhook-observe 也会把事件转入正式 webhook pipeline。
DY_LIVE_CHECK_FORWARD_TO_FORMAL=false

# ---------- 旧链路开关 ----------
# 旧 wechat_auto_detect_scheduler 默认禁用；新主线使用 19000 Local Agent 操作微信。
# 设置为 1 可恢复旧调度器，仅供开发调试或回退使用，生产不要开启。
AUTO_WECHAT_ENABLE_LEGACY_AUTO_DETECT=0

# ---------- 9000 调用 9202 AI小高线索 internal webhook ----------
# 默认关闭，确保正式 webhook 行为与旧链路一致；只有接入 9202 内部线索服务时才开启。
LEADS_WEBHOOK_INTERNAL_ENABLED=false
# 9202 内部线索服务不可用时是否回退到 9000 本地处理逻辑。
LEADS_WEBHOOK_FALLBACK_LOCAL=true
# 9202 AI小高线索服务地址；仅在 LEADS_WEBHOOK_INTERNAL_ENABLED=true 时使用。
LEADS_SERVICE_BASE_URL=http://127.0.0.1:9202
# 9000 调用 9202 的内部令牌；按 9202 约定填写。
LEADS_INTERNAL_TOKEN=
# 9000 调用 9202 的请求超时时间，单位：秒。
LEADS_CLIENT_TIMEOUT_SECONDS=20

# ---------- Local Agent 机器身份鉴权 ----------
# 兼容模式默认不强制，旧 19000 无 token 仍可工作，但后端会记录 warning。
# 灰度确认所有 Local Agent 已带 X-Local-Agent-Token 后，再切为 true。
LOCAL_AGENT_AUTH_REQUIRED=false
# 格式：merchant_id:token,merchant_id2:token2。token 只放后端 / Agent 配置，禁止写入任何 VITE_*。
LOCAL_AGENT_TOKENS=demo_merchant_001:local-agent-dev-token

# ---------- 历史微信调试接口 ----------
# 默认关闭，减少公网暴露面。production 环境即使设为 true 也会强制关闭。
# 仅本地排查旧接口时临时开启；不要配置为任何 VITE_*。
LEGACY_WECHAT_DEBUG_ENDPOINTS_ENABLED=false

# ---------- 9100 抖音AI小高客服：SQLite 数据库 ----------
# P2-A 已支持 RAG_DATABASE_URL 配置抽象；默认仍使用 SQLite。
# 本地直启默认落到 apps/xg_douyin_ai_cs/data/xg_douyin_ai_cs.db。
# Docker 本地开发会在 docker-compose.dev.yml 中映射为 /data/xg_douyin_ai_cs.db。
# RAG_DATABASE_URL=sqlite:////data/xg_douyin_ai_cs.db
# P2-D 可选 PostgreSQL dev profile 示例；默认不要取消注释，后续切换任务再启用。
# RAG_DATABASE_URL=postgresql+asyncpg://xg_douyin_ai_cs:change_me@postgres:5432/xg_douyin_ai_cs
# P2-E RAG metadata 连接池预留配置；当前只读取配置，不创建 pool。QPS600 生产值必须压测后确定，不要直接照搬默认值。
# RAG_DB_POOL_SIZE=20
# RAG_DB_MAX_OVERFLOW=40
# RAG_DB_POOL_TIMEOUT=30
# RAG_DB_POOL_RECYCLE=1800
# RAG_DB_STATEMENT_TIMEOUT_MS=5000
XG_DOUYIN_AI_CS_DB_PATH=apps/xg_douyin_ai_cs/data/xg_douyin_ai_cs.db

# ---------- 9100 抖音AI小高客服：RAG 向量库后端 ----------
# 本地默认 sqlite，不需要 Milvus。
# Milvus 仅建议在 staging / production 显式启用；真实账号密码只能写入本机 .env 或部署环境变量，不得提交。
RAG_VECTOR_BACKEND=sqlite
# RAG_VECTOR_BACKEND=milvus 时才读取以下配置。
MILVUS_URI=
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_DB_NAME=
MILVUS_COLLECTION=
MILVUS_DIMENSION=
MILVUS_TIMEOUT_SECONDS=5
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE

# ---------- 9100 抖音AI小高客服：LLM 对话配置 ----------
# 示例文件不要填写真实 API Key。真实密钥只写入本机 .env 或部署平台密钥配置。
# base_url 使用 OpenAI 兼容接口地址，可接 OpenAI、OpenRouter 或其它兼容服务。
XG_DOUYIN_AI_LLM_BASE_URL=https://api.openai.com/v1
# 留空时 9100 不会真实调用 LLM，回复建议会走人工兜底。
XG_DOUYIN_AI_LLM_API_KEY=
# 对话模型名，由所选 base_url 对应的服务决定。
XG_DOUYIN_AI_LLM_CHAT_MODEL=gpt-4o-mini
# 旧 embedding 模型配置，保留兼容；新部署优先使用下面独立的 XG_DOUYIN_AI_EMBEDDING_*。
XG_DOUYIN_AI_LLM_EMBEDDING_MODEL=text-embedding-3-small
# 旧 embedding 开关，仅当 XG_DOUYIN_AI_EMBEDDING_ENABLED 未设置时作为 fallback。
XG_DOUYIN_AI_LLM_EMBEDDING_ENABLED=false
# LLM 对话请求超时时间，单位：秒。
XG_DOUYIN_AI_LLM_TIMEOUT_SECONDS=60
# LLM 采样温度；越低越稳定，客服建议默认保持 0.2。
XG_DOUYIN_AI_LLM_TEMPERATURE=0.2

# ---------- 9100 抖音AI小高客服：Embedding 配置 ----------
# chat 走 XG_DOUYIN_AI_LLM_*；embedding 走 XG_DOUYIN_AI_EMBEDDING_*，两套配置互相独立。
# 默认 ENABLED=false：未配置或 key 为空时，RAG 训练使用本地 mock embedding，不产生外部调用和 token 消耗。
# 启用真实 Ark embedding 需要同时设置 ENABLED=true 与有效的 EMBEDDING_API_KEY。
XG_DOUYIN_AI_EMBEDDING_ENABLED=false
# 当前实现只在 provider=ark 且 api_key 非空时真实调用火山方舟。
XG_DOUYIN_AI_EMBEDDING_PROVIDER=ark
XG_DOUYIN_AI_EMBEDDING_API_KEY=
XG_DOUYIN_AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
XG_DOUYIN_AI_EMBEDDING_ENDPOINT=/embeddings/multimodal
XG_DOUYIN_AI_EMBEDDING_MODEL=doubao-embedding-vision-250615
# 留空表示不传 dimensions，使用 Ark 服务端默认维度。
XG_DOUYIN_AI_EMBEDDING_DIMENSIONS=
XG_DOUYIN_AI_EMBEDDING_ENCODING_FORMAT=float
# 稀疏向量本阶段默认关闭，不入库；后续混合检索需要单独评审后再开启。
XG_DOUYIN_AI_EMBEDDING_SPARSE_ENABLED=false
# embedding 请求超时时间，单位：秒。
XG_DOUYIN_AI_EMBEDDING_TIMEOUT_SECONDS=120

# ---------- 9100 抖音AI小高客服：Agent Runtime 预留 ----------
# 默认关闭。一期不安装 LangChain、不调用真实 tool、不替换现有 LLM 主链路。
XG_DOUYIN_AI_AGENT_RUNTIME_ENABLED=false

# ---------- 前端浏览器 API 地址提示 ----------
# VITE_API_BASE_URL / VITE_AUTO_WECHAT_API_BASE_URL / VITE_DOUYIN_AI_CS_API_BASE_URL 是浏览器访问地址。
# 公网访问时不要写 compose service name，应填写公网域名或浏览器可访问的服务地址。
# VITE_LOCAL_WECHAT_AGENT_BASE_URL 保持 127.0.0.1:19000，指向浏览器所在 Windows 电脑本机 Agent。
