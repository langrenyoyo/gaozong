# 版本控制
.git
.gitignore

# 环境变量（含密钥，禁止进入镜像）
.env

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# 数据库运行时文件
data/*.db
data/*.db-wal
data/*.db-shm
data/*.log
data/debug_screenshots/

# 虚拟环境
.venv/
venv/

# IDE / 工具本地配置
.vscode/
.claude/

# 构建产物
app/local_agent_build_info.py
dist/
build/
*.egg-info/
*.spec

# 日志
logs/

# Docker 相关（避免递归）
docker-compose*.yml
Dockerfile

# 文档和临时文件
docs/
*.md
test_cors_leads.json
test_wechat_debug.json
@AutomationLog.txt
resources/
