# 版本控制
.git
.gitignore

# 环境变量（含密钥，禁止进入镜像）
.env

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# 数据库运行时文件
data/*.db
data/*.db-wal
data/*.db-shm
data/*.log
data/debug_screenshots/

# 虚拟环境
.venv/
venv/

# IDE / 工具本地配置
.vscode/
.claude/

# 构建产物
app/local_agent_build_info.py
dist/
build/
*.egg-info/
*.spec

# 日志
logs/
*.log

# Docker 相关（避免递归）
docker-compose*.yml
Dockerfile

# 文档和临时文件
docs/
*.md
test_cors_leads.json
test_wechat_debug.json
@AutomationLog.txt
resources/

# 环境变量（含示例模板）不进入镜像；运行时由 compose env_file 注入。
.env*

# 前端依赖与构建产物（不进镜像）
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# 本地数据库与运行数据（不进镜像）
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
docker-data/


# Python test and tool caches
**/.pytest_cache
**/__pycache__
**/*.py[cod]
**/.mypy_cache
**/.ruff_cache
**/.coverage
**/htmlcov