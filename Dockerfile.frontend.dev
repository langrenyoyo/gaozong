# 本地开发调试用前端镜像（React + Vite，端口 5173）
#
# 说明：
# - 使用 node:22-slim（当前 LTS）。选择 22 而非 24 的原因：
#   22 是 Node 官方长期支持版本，与 Vite 7（要求 node ^20.19 || >=22.12）
#   及 React 生态的兼容性验证最充分；24 非 LTS，镜像生态偶有滞后。
#   宿主机虽为 node 24，但容器用 22 LTS 更稳妥。
# - 构建期 COPY package*.json 并 npm install（缓存依赖层）。
# - 运行期由 docker-compose.dev.yml 挂载 ./frontend 源码并匿名隔离 node_modules，
#   实现源码热更新，同时避免宿主机（Windows）与容器（Linux）二进制不兼容。
FROM node:22-slim

WORKDIR /workspace/frontend

# 先装依赖（利用层缓存，源码改动不触发重装）
COPY frontend/package.json frontend/package-lock.json ./
RUN npm config set registry https://registry.npmmirror.com/ && \
    npm install --no-fund --no-audit

EXPOSE 5173

# Vite 开发服务器，绑定 0.0.0.0 让宿主机可访问
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
