# ==============================================================================
# 00. 文件用途与复制方式
#
# 本文件是 auto_wechat 正式生产环境（宝塔部署）的配置模板。
# 所有真实密钥都使用 <中文占位符> 表示，部署时替换为真实值。
#
# 生产环境定调（不得违背）：
# - 数据库：9000 PostgreSQL + 9100 独立 PostgreSQL database（一个实例两个库）。
# - 向量库：外部独立 Milvus，不由本项目 Docker Compose 部署。
# - 鉴权：真实 NewCar（mock 必须关闭）。
# - Local Agent：运行在销售 Windows 电脑，不运行在宝塔服务器。
# - 禁止：mock auth、业务 SQLite 回退、LAN 地址、开发密码。
#
# 复制与权限：
#   cp .env.production.example .env.production.local
#   chmod 600 .env.production.local
#
# 安全约束：
# - .env.production.local 不得提交 Git（.gitignore 已忽略）。
# - 真实密码不得粘贴到聊天和日志。
# - production 脚本（scripts/production_pg_*.sh）只读取 .env.production.local。
#
# 完整变量说明见 docs/config/ENV_VARIABLE_REFERENCE.md。
# ==============================================================================


# ==============================================================================
# 01. 当前环境身份
#
# APP_ENV 由 app/config.py 读取，决定 webhook 验签是否强制、is_production_env() 判定。
# production 环境下，即使 DOUYIN_WEBHOOK_AUTH_REQUIRED=false 也强制验签（config.py:327）。
# PYTHONUNBUFFERED 由容器读取，保证 uvicorn 日志不缓冲、实时输出。
# ==============================================================================
APP_ENV=production
PYTHONUNBUFFERED=1


# ==============================================================================
# 02. 服务地址与网络边界
#
# 生产部署在宝塔 Docker Compose，容器间通过 Compose service name 通信。
# 容器内不得使用 localhost / 127.0.0.1 访问另一个容器（那是容器自己）。
# 只有 VITE_LOCAL_WECHAT_AGENT_BASE_URL 是例外：它指向销售浏览器所在电脑，永远是 127.0.0.1。
#
# 网络边界速查：
# - 容器 → 容器（同一 Compose）：用 service name（postgres / xg-douyin-ai-cs / auto-wechat-api）。
# - 容器 → 外部服务（Milvus / NewCar / 抖音）：用外部真实地址。
# - 浏览器 → 9000：通过宝塔反代域名（https）。
# - 浏览器 → 本机 Agent：127.0.0.1:19000（销售电脑自己）。
# ==============================================================================


# ==============================================================================
# 03. 9000 主数据库（PostgreSQL）
#
# 调用链：
#   PG_USER/PG_PASSWORD/PG_DB → docker-compose 初始化 PostgreSQL 容器主库
#   DATABASE_URL → app/config.py → app/database.py create_database_engine() PG 分支
#   EXPECTED_DATABASE_NAME → app/routers/health.py 9000 /ready 校验当前连接库名
#
# 关键约束：
# - PG_DB 是 PostgreSQL 容器首次初始化创建的主库（POSTGRES_DB）。
# - DATABASE_URL 必须指向 9000 主库 auto_wechat，scheme 用 postgresql+psycopg（同步）。
# - RAG_DATABASE_URL 必须指向 9100 独立库 xg_douyin_ai_cs，与 DATABASE_URL 不同库。
# - 容器内 host 必须用 Compose service name postgres，不能写 localhost。
# - readiness 会比对连接库名与 EXPECTED_DATABASE_NAME，不匹配则 503。
# - production 不允许缺少 DATABASE_URL 后回退 SQLite（dev 才回退）。
#
# 第二数据库注意：已有 PG volume 不会自动创建第二个 database，
# 需通过初始化脚本或迁移脚本显式创建 xg_douyin_ai_cs。
# ==============================================================================
PG_USER=<请填写生产PostgreSQL用户名>
PG_PASSWORD=<请填写生产PostgreSQL密码>
PG_DB=auto_wechat
DATABASE_URL=postgresql+psycopg://<请填写生产PostgreSQL用户名>:<请填写生产PostgreSQL密码>@postgres:5432/auto_wechat
RAG_DATABASE_URL=postgresql+psycopg://<请填写生产PostgreSQL用户名>:<请填写生产PostgreSQL密码>@postgres:5432/xg_douyin_ai_cs
EXPECTED_DATABASE_NAME=auto_wechat
RAG_EXPECTED_DATABASE_NAME=xg_douyin_ai_cs


# ==============================================================================
# 04. 9000 PostgreSQL 连接池（DB_POOL_*）
#
# 调用链（以代码读取点为准，不得凭变量名猜测）：
#   DB_POOL_* → app/config.py 读取 → app/database.py create_database_engine() PG 分支（line 192-200）
#   → SQLAlchemy create_engine(postgresql+psycopg, pool_size=DB_POOL_SIZE, ...)
#   → 9000 PostgreSQL 同步 engine（生产实际生效）
#
# 变量含义（单位以代码为准）：
# - DB_POOL_SIZE：常驻连接数（默认 20）。
# - DB_MAX_OVERFLOW：池满后的临时溢出连接数（默认 40）。SIZE+OVERFLOW=单进程最大连接。
# - DB_POOL_TIMEOUT：等待可用连接的秒数（默认 30）。
# - DB_POOL_RECYCLE：连接回收周期秒（默认 1800），避免 PG 端踢连接。
# - DB_STATEMENT_TIMEOUT_MS：每条语句超时毫秒，connect 事件 SET statement_timeout（默认 5000）。
#
# 注意：SQLALCHEMY_* 只控制 SQLite engine（dev/lan），不影响 production PostgreSQL。
# 生产只配 DB_POOL_*，不配 SQLALCHEMY_*。总连接数须结合 PG max_connections 评估。
# 详见 docs/config/ENV_VARIABLE_REFERENCE.md 第 6 节。
# ==============================================================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=5000


# ==============================================================================
# 05. 9100 RAG metadata PostgreSQL 连接池（RAG_DB_POOL_*）
#
# 调用链：
#   RAG_DB_POOL_* → apps/xg_douyin_ai_cs/config.py settings.rag_db_*
#   → apps/xg_douyin_ai_cs/rag/database.py create_rag_engine() PG 分支（line 80-96）
#   → 9100 RAG PostgreSQL engine（生产实际生效）
#
# 含义同 DB_POOL_*，但作用于 9100 RAG metadata 库（xg_douyin_ai_cs）。
# pool_size + max_overflow 是 9100 单进程对 RAG 库的最大连接数。
# 须与 9000 DB_POOL_* 一起纳入 PG max_connections 总预算。
# ==============================================================================
RAG_DB_POOL_SIZE=20
RAG_DB_MAX_OVERFLOW=40
RAG_DB_POOL_TIMEOUT=30
RAG_DB_POOL_RECYCLE=1800
RAG_DB_STATEMENT_TIMEOUT_MS=5000


# ==============================================================================
# 06. NewCar 外部鉴权
#
# 调用链（真实登录流程）：
#   1. 浏览器访问前端 → token 失效 → 前端读 VITE_NEWCAR_LOGIN_URL 跳转 NewCar 登录页
#   2. NewCar 登录成功 → 携带 code 回跳 9000 /auth/callback
#   3. 9000 调 NEWCAR_AUTH_EXCHANGE_CODE_URL 用 code 换 token
#   4. 后续请求 9000 调 NEWCAR_AUTH_ME_URL 校验 token + 取商户身份（external-auth/me）
#   5. 退出登录 9000 调 NEWCAR_AUTH_LOGOUT_URL（POST /auth/logout）
#
# 读取点：app/config.py:256-264。
#
# 关键约束：
# - production 必须 NEWCAR_AUTH_ENABLED=true、NEWCAR_AUTH_MOCK_ENABLED=false。
# - NEWCAR_AUTH_BASE_URL 是 NewCar 认证服务根地址（末尾不带斜杠）。
# - EXCHANGE_CODE_URL / ME_URL / LOGOUT_URL 留空时由 BASE_URL + 既定路径拼接；
#   如 NewCar 路径非标可填完整 URL 覆盖。
# - LOGIN_URL 是浏览器跳转的登录页地址（前端用，但放这里供后端统一记录）。
# - SERVICE_TOKEN 是 9000 调 NewCar 的服务间令牌（X-NewCar-Service-Token 头）。
# - TIMEOUT_SECONDS 是 9000 调 NewCar 的超时秒数。
# - 地址必须能从 9000 容器内部访问，不要填只有浏览器能访问的地址。
# ==============================================================================
NEWCAR_AUTH_ENABLED=true
NEWCAR_AUTH_MOCK_ENABLED=false
NEWCAR_AUTH_BASE_URL=https://<请填写NewCar认证服务域名>
NEWCAR_AUTH_EXCHANGE_CODE_URL=
NEWCAR_AUTH_ME_URL=
NEWCAR_AUTH_LOGOUT_URL=
NEWCAR_AUTH_LOGIN_URL=https://<请填写NewCar登录页域名>/login
NEWCAR_AUTH_SERVICE_TOKEN=<请填写NewCar服务间令牌>
NEWCAR_AUTH_TIMEOUT_SECONDS=5


# ==============================================================================
# 07. 服务间鉴权与内部安全密钥
#
# 调用链：
# - XG_DOUYIN_AI_CS_BASE_URL/TOKEN：9000 → 9100 可信代理（config.py:267-269）。
# - AUTO_WECHAT_9000_BASE_URL：9100 → 9000 上报算力用量（compute_usage_client.py:43）。
# - COMPUTE_INTERNAL_TOKEN：9000/9100 双向校验内部算力接口（compute.py:241 + compute_usage_client.py:44）。
# - LOCAL_AGENT_AUTH_REQUIRED/TOKENS：9000 校验 Local Agent 心跳 token（config.py:308-309）。
# - KNOWLEDGE_TRAINING_*：知识库训练内部接口保护（config.py:272-287）。
#
# 关键约束：
# - XG_DOUYIN_AI_CS_BASE_URL 用 Compose service name http://xg-douyin-ai-cs:9100。
# - AUTO_WECHAT_9000_BASE_URL 用 Compose service name http://auto-wechat-api:9000。
# - LOCAL_AGENT_TOKENS 格式 merchant_id:token，逗号分隔多商户。
# - KNOWLEDGE_TRAINING_IP_WHITELIST 限制训练接口只接受可信管理 IP/CIDR。
# - KNOWLEDGE_TRAINING_TRUST_PROXY_HEADERS=true 时信任 X-Forwarded-For（宝塔反代后必须开）。
# ==============================================================================
XG_DOUYIN_AI_CS_BASE_URL=http://xg-douyin-ai-cs:9100
XG_DOUYIN_AI_CS_SERVICE_TOKEN=<请填写9100内部服务令牌>
XG_DOUYIN_AI_CS_TIMEOUT_SECONDS=60
AUTO_WECHAT_9000_BASE_URL=http://auto-wechat-api:9000
COMPUTE_INTERNAL_TOKEN=<请填写算力内部令牌>
COMPUTE_USAGE_TIMEOUT_SECONDS=20
LOCAL_AGENT_AUTH_REQUIRED=true
LOCAL_AGENT_TOKENS=<请填写商户ID>:<请填写Local-Agent令牌>
KNOWLEDGE_TRAINING_IP_WHITELIST=<请填写可信管理IP或CIDR>
KNOWLEDGE_TRAINING_INTERNAL_TOKENS=<请填写知识训练令牌>
KNOWLEDGE_TRAINING_DEFAULT_TENANT_ID=xiaogao_system
KNOWLEDGE_TRAINING_DEFAULT_MERCHANT_ID=xiaogao_base
KNOWLEDGE_TRAINING_TRUST_PROXY_HEADERS=true


# ==============================================================================
# 08. 抖音开放平台与 OAuth
#
# 调用链：
# - DY_SECRET_KEY：webhook 入站验签 sha256Hex(SECRET_KEY + body + "-" + timestamp)（config.py:224）。
# - DY_GMP_SECRET_KEY：抖音 OpenAPI 请求签名密钥（config.py:225）。
# - DY_OPENAPI_BASE_URL/PREFIX：OpenAPI 域名与路径前缀，拼接为完整 base（config.py:226-229）。
# - DY_MAIN_ACCOUNT_ID/ACCOUNT_NAME：主账户标识（config.py:230-231）。
# - DY_HTTP_TIMEOUT_SECONDS：OpenAPI 请求超时秒（config.py:232）。
# - DY_ALLOWED_DRIFT_SECONDS：webhook 时间戳漂移容忍窗口秒（config.py:233）。
# - DY_OAUTH_STATE_TTL_SECONDS：OAuth state 有效期秒，防 CSRF（config.py:248）。
# - DOUYIN_WEBHOOK_AUTH_REQUIRED：入站 webhook 是否强制验签（production 无论此值都强制）。
# - PUBLIC_BASE_URL：9000 对外可访问地址（webhook 注册给抖音）（config.py:234）。
# - DY_AUTH_REDIRECT_URL：OAuth 回跳地址，后端 /auth-redirect 校验 state 并同步账号（config.py:247）。
# - DY_AUTH_REDIRECT_FRONTEND_URL：授权完成后 302 跳回前端地址（config.py:251）。
# - DY_AUTH_REDIRECT_ALLOWED_ORIGINS：OAuth 前端 origin 白名单（config.py:252）。
# - DY_CALLBACK_URL：抖音事件回调地址（config.py:246）。
# - DY_CALLBACK_EVENTS：订阅的回调事件类型（config.py:241-245）。
#
# production 安全约束：
# - DOUYIN_WEBHOOK_AUTH_REQUIRED 必须为 true（production 下即使 false 也强制验签）。
# - 所有 URL 用 https 对外域名，不能用 localhost / LAN IP。
# - DY_SECRET_KEY / DY_GMP_SECRET_KEY 是敏感密钥，必须填真实值。
# ==============================================================================
DY_SECRET_KEY=<请填写抖音webhook验签密钥>
DY_GMP_SECRET_KEY=<请填写抖音OpenAPI签名密钥>
DY_OPENAPI_BASE_URL=https://gmp.bytedanceapi.com
DY_OPENAPI_PREFIX=/ai_chat_agent_api/v1/openapi
DY_MAIN_ACCOUNT_ID=<请填写抖音主账户ID>
DY_ACCOUNT_NAME=<请填写抖音主账户名称>
DY_HTTP_TIMEOUT_SECONDS=20
DY_ALLOWED_DRIFT_SECONDS=300
DY_OAUTH_STATE_TTL_SECONDS=900
DOUYIN_WEBHOOK_AUTH_REQUIRED=true
PUBLIC_BASE_URL=https://callback.misanduo.com
DY_AUTH_REDIRECT_URL=https://callback.misanduo.com/integrations/douyin/live-check/auth-redirect
DY_AUTH_REDIRECT_FRONTEND_URL=https://<请填写前端域名>
DY_AUTH_REDIRECT_ALLOWED_ORIGINS=https://<请填写前端域名>
DY_CALLBACK_URL=https://callback.misanduo.com/integrations/douyin/live-check/webhook-observe
DY_CALLBACK_EVENTS=im_receive_msg,im_send_msg,im_enter_direct_msg


# ==============================================================================
# 09. 抖音 Live Check
#
# 调用链：app/config.py:235-237 + live-check 路由。
# - DY_LIVE_CHECK_ENABLED：现场观察模式总开关。开启后可观察抖音事件不触发正式链路。
# - DY_LIVE_CHECK_FORWARD_TO_FORMAL：观察到的事件是否同时转入正式 pipeline。
#   风险：true 时观察事件会影响真实业务（写入线索、触发通知），生产默认 false。
# - DOUYIN_RESOURCE_ALLOWED_HOSTS：live-check 资源下载 SSRF 白名单，逗号分隔域名。
#   留空走代码默认拦截；只允许可信 CDN 域名，防内网探测。
#
# production 默认关闭 live-check；需要现场观察时临时在 .local 开启。
# ==============================================================================
DY_LIVE_CHECK_ENABLED=false
DY_LIVE_CHECK_FORWARD_TO_FORMAL=false
DOUYIN_RESOURCE_ALLOWED_HOSTS=<请填写抖音资源CDN域名白名单>


# ==============================================================================
# 10. 抖音自动回复与白名单
#
# 调用链：app/config.py:291-296 + 自动回复 gate 路由。
#
# 三级开关（默认全 false，真实发送需同时打开前两个）：
# - DOUYIN_AUTO_REPLY_ENABLED：自动回复总开关。
# - DOUYIN_AUTO_REPLY_REAL_SEND_ENABLED：真实发送开关（false 只出建议不发送）。
# - DOUYIN_AUTO_REPLY_ALLOW_FULL_ROLLOUT：全量放开开关（false 走白名单灰度）。
#
# 三种白名单（逗号分隔，空值=该维度不限制但受其他开关约束）：
# - DOUYIN_AUTO_REPLY_ACCOUNT_WHITELIST：允许自动回复的企业号 open_id 列表。
# - DOUYIN_AUTO_REPLY_CUSTOMER_WHITELIST：允许自动回复的客户 open_id 列表。
# - DOUYIN_AUTO_REPLY_CONVERSATION_WHITELIST：允许自动回复的会话 key 列表。
#
# production 门禁：开启真实发送前必须确认全量模式与白名单策略，
# 并保留违禁词替换、人工接管、限频、失败回写、幂等、紧急停止。
# 空白名单的真实行为见 config.py _env_csv_set：空集=不匹配任何项。
# ==============================================================================
DOUYIN_AUTO_REPLY_ENABLED=false
DOUYIN_AUTO_REPLY_REAL_SEND_ENABLED=false
DOUYIN_AUTO_REPLY_ALLOW_FULL_ROLLOUT=false
DOUYIN_AUTO_REPLY_ACCOUNT_WHITELIST=
DOUYIN_AUTO_REPLY_CUSTOMER_WHITELIST=
DOUYIN_AUTO_REPLY_CONVERSATION_WHITELIST=


# ==============================================================================
# 11. Leads 9202 内部服务
#
# 调用链：app/config.py:300-304。
# - LEADS_SERVICE_BASE_URL：9000 调用 9202 AI小高线索 internal webhook 的地址。
# - LEADS_INTERNAL_TOKEN：9000 调 9202 的服务间令牌，双方必须一致。
# - LEADS_CLIENT_TIMEOUT_SECONDS：9000 调 9202 的超时秒。
# - LEADS_WEBHOOK_INTERNAL_ENABLED：是否把 webhook 事件转发给 9202 internal 链路。
# - LEADS_WEBHOOK_FALLBACK_LOCAL：9202 不可用时是否回退本地处理。
#
# production 约束：
# - 开启 internal webhook 前必须确认 LEADS_SERVICE_BASE_URL 与 token 正确。
# - production 只有 token 没有 URL 是无效配置（token 无法补偿缺失地址）。
# - 默认 LEADS_WEBHOOK_INTERNAL_ENABLED=false，保持 webhook 直收行为。
# ==============================================================================
LEADS_SERVICE_BASE_URL=<请填写9202线索服务地址>
LEADS_INTERNAL_TOKEN=<请填写9202内部令牌>
LEADS_CLIENT_TIMEOUT_SECONDS=5
LEADS_WEBHOOK_INTERNAL_ENABLED=false
LEADS_WEBHOOK_FALLBACK_LOCAL=true


# ==============================================================================
# 12. 9100 LLM（对话模型）
#
# 调用链：apps/xg_douyin_ai_cs/llm/config.py load_llm_config()。
# - XG_DOUYIN_AI_LLM_BASE_URL：LLM 兼容接口地址（OpenRouter / OpenAI 兼容）。
# - XG_DOUYIN_AI_LLM_API_KEY：LLM API key（敏感）。
# - XG_DOUYIN_AI_LLM_CHAT_MODEL：对话模型名。
# - XG_DOUYIN_AI_LLM_TIMEOUT_SECONDS：LLM 请求超时秒。
# - XG_DOUYIN_AI_LLM_TEMPERATURE：采样温度（0-1）。
# - XG_DOUYIN_AI_AGENT_RUNTIME_ENABLED：9100 Agent runtime 预留开关（agent_runtime.py:32）。
#
# 注意：LLM（chat）和 Embedding 是两套独立配置，不共享 key / base_url。
# 旧兼容变量 XG_DOUYIN_AI_LLM_EMBEDDING_* 不进入模板，见参考文档第 4 节。
# ==============================================================================
XG_DOUYIN_AI_LLM_BASE_URL=https://api.openai.com/v1
XG_DOUYIN_AI_LLM_API_KEY=<请填写LLM-API-Key>
XG_DOUYIN_AI_LLM_CHAT_MODEL=gpt-4o-mini
XG_DOUYIN_AI_LLM_TIMEOUT_SECONDS=60
XG_DOUYIN_AI_LLM_TEMPERATURE=0.2
XG_DOUYIN_AI_AGENT_RUNTIME_ENABLED=false


# ==============================================================================
# 13. 9100 Embedding（火山方舟 Ark）
#
# 调用链：apps/xg_douyin_ai_cs/llm/embedding_config.py load_embedding_config()。
# 训练知识库 → embedding 文档分块；检索 query → embedding 后查 Milvus。
#
# 变量含义：
# - XG_DOUYIN_AI_EMBEDDING_ENABLED：embedding 总开关。
#   false 时走本地 mock_embedding（零费用、零外部调用、零启动报错）。
#   true 时需 API_KEY + PROVIDER=ark 才真实调用（real_enabled 三条件，embedding_config.py:49-53）。
# - PROVIDER：提供方，当前固定 ark（火山方舟）。
# - API_KEY：Ark API key（敏感）。
# - BASE_URL：Ark 服务根地址（末尾不带斜杠）。
# - ENDPOINT：embedding 端点路径，与 BASE_URL 拼接为完整地址。
# - MODEL：embedding 模型名。
# - DIMENSIONS：向量维度，必须与 MILVUS_DIMENSION 和 collection 实际维度一致。
# - ENCODING_FORMAT：编码格式（float）。
# - SPARSE_ENABLED：稀疏向量开关（当前向量后端未真实使用，预留）。
# - TIMEOUT_SECONDS：embedding 请求超时秒。
#
# 维度一致性：XG_DOUYIN_AI_EMBEDDING_DIMENSIONS = MILVUS_DIMENSION = collection 实际维度。
# 不一致 → readiness MILVUS_DIMENSION_MISMATCH，启动失败。
# ==============================================================================
XG_DOUYIN_AI_EMBEDDING_ENABLED=false
XG_DOUYIN_AI_EMBEDDING_PROVIDER=ark
XG_DOUYIN_AI_EMBEDDING_API_KEY=<请填写Ark-Embedding-API-Key>
XG_DOUYIN_AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
XG_DOUYIN_AI_EMBEDDING_ENDPOINT=/embeddings/multimodal
XG_DOUYIN_AI_EMBEDDING_MODEL=doubao-embedding-vision-250615
XG_DOUYIN_AI_EMBEDDING_DIMENSIONS=2048
XG_DOUYIN_AI_EMBEDDING_ENCODING_FORMAT=float
XG_DOUYIN_AI_EMBEDDING_SPARSE_ENABLED=false
XG_DOUYIN_AI_EMBEDDING_TIMEOUT_SECONDS=120


# ==============================================================================
# 14. 外部 Milvus（向量后端，production 固定使用）
#
# 调用链：
#   MILVUS_* → apps/xg_douyin_ai_cs/config.py settings.milvus_*
#   → apps/xg_douyin_ai_cs/services/vector_store.py MilvusVectorStore.connect()
#   → pymilvus connections.connect(host, user, password, db_name)
#
# production 定调：
# - RAG_VECTOR_BACKEND 固定 milvus，不得改为 sqlite。
# - Milvus 是外部独立服务，不由本项目 Compose 部署（compose 无 milvus service）。
# - 9100 通过 MILVUS_* 连接外部 Milvus；Milvus 不可达 → readiness 503，不回退 SQLite。
# - production collection 不得与 dev/LAN collection 共用。
#
# 变量含义：
# - MILVUS_URI：外部 Milvus 连接地址（http://host:19530），必须能从 9100 容器访问。
# - MILVUS_USERNAME/PASSWORD：Milvus 认证凭据（敏感）。
# - MILVUS_DB_NAME：Milvus database 名（database 是 Milvus 内部逻辑隔离层）。
# - MILVUS_COLLECTION：Milvus collection 名（collection 是实际向量存储，prod 专属）。
# - MILVUS_DIMENSION：向量维度，必须与 Embedding DIMENSIONS 和 collection 实际维度一致。
# - MILVUS_TIMEOUT_SECONDS：Milvus 请求超时秒。
# - MILVUS_INDEX_TYPE：索引类型（AUTOINDEX）。
# - MILVUS_METRIC_TYPE：度量类型（COSINE）。
# - MILVUS_CONNECT_STRATEGY：连接策略（orm）。
#
# dimension 一致性三层校验（run_milvus_readiness）：
#   XG_DOUYIN_AI_EMBEDDING_DIMENSIONS == MILVUS_DIMENSION == collection 实际维度
# ==============================================================================
RAG_VECTOR_BACKEND=milvus
MILVUS_URI=<请填写外部Milvus连接地址>
MILVUS_USERNAME=<请填写Milvus用户名>
MILVUS_PASSWORD=<请填写Milvus密码>
MILVUS_DB_NAME=<请填写Milvus数据库名>
MILVUS_COLLECTION=<请填写生产Milvus-Collection名>
MILVUS_DIMENSION=2048
MILVUS_TIMEOUT_SECONDS=5
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE
MILVUS_CONNECT_STRATEGY=orm


# ==============================================================================
# 15. Local Agent（浏览器地址，非宝塔进程）
#
# production 不在宝塔启动 Local Agent。Local Agent（小高AI微信助手.exe）运行在
# 销售 Windows 电脑，监听 127.0.0.1:19000，操作本机微信。
#
# VITE_LOCAL_WECHAT_AGENT_BASE_URL 是前端部署约定值，提醒部署人员：
# - 127.0.0.1 指销售浏览器所在的 Windows 电脑，不是宝塔服务器，不是 9000 容器。
# - 前端实际从浏览器 localStorage 的 local_wechat_agent_url 键读取（默认 http://127.0.0.1:19000），
#   此 VITE 变量为部署文档约定，保留在模板中作为标准值。
# - Local Agent exe 需在销售电脑独立部署，不由宝塔管理。
#
# Local Agent 的 7 个 Python 进程变量（LOCAL_AGENT_HOST/PORT、AUTO_WECHAT_SERVER_URL 等）
# 不进入 production 模板——它们只在销售电脑 exe 本地 .env 生效，与宝塔无关。
# 详见 .env.development.example 第 16 节。
# ==============================================================================
VITE_LOCAL_WECHAT_AGENT_BASE_URL=http://127.0.0.1:19000


# ==============================================================================
# 16. 前端 Vite 配置（浏览器 + dev proxy）
#
# 读取点：
# - VITE_API_BASE_URL / VITE_AUTO_WECHAT_API_BASE_URL → frontend/src/api/client.ts（9000 baseURL）。
# - VITE_DOUYIN_AI_CS_API_BASE_URL → frontend/src/api/douyinAiCsClient.ts（9100 baseURL）。
# - VITE_NEWCAR_AUTH_BASE_URL → frontend/src/api/auth.ts（浏览器直连 NewCar 换 token）。
# - VITE_NEWCAR_LOGIN_URL → frontend/src/newcarRedirect.ts（登录失效跳转）。
# - VITE_DEV_API_PROXY_TARGET / VITE_DEV_DOUYIN_AI_CS_PROXY_TARGET → frontend/vite.config.ts（dev/preview proxy）。
#
# production 约定：
# - VITE_API_BASE_URL=/api：浏览器请求走宝塔反代 /api → 9000。
# - VITE_DOUYIN_AI_CS_API_BASE_URL=/ai-cs-api：浏览器请求走反代 /ai-cs-api → 9100。
# - VITE_NEWCAR_AUTH_BASE_URL / VITE_NEWCAR_LOGIN_URL：填 NewCar 真实 https 域名。
# - VITE_DEV_*_PROXY_TARGET：容器内 vite preview 静态服务的反代目标，用 Compose service name。
#
# Vite 通过 envDir: ".." 从项目根目录读取 .env（含本模板），不从 frontend/ 子目录读。
# ==============================================================================
VITE_API_BASE_URL=/api
VITE_AUTO_WECHAT_API_BASE_URL=/api
VITE_DOUYIN_AI_CS_API_BASE_URL=/ai-cs-api
VITE_NEWCAR_AUTH_BASE_URL=https://<请填写NewCar认证服务域名>
VITE_NEWCAR_LOGIN_URL=https://<请填写NewCar登录页域名>/login
VITE_DEV_API_PROXY_TARGET=http://auto-wechat-api:9000
VITE_DEV_DOUYIN_AI_CS_PROXY_TARGET=http://xg-douyin-ai-cs:9100


# ==============================================================================
# 17. CORS 与公开地址
#
# 调用链：app/config.py:147-155（_env_csv_set 解析逗号分隔）。
# CORS_ORIGINS：允许跨域请求的来源白名单。
# production 必须填真实前端域名，不能用 localhost / LAN IP / 通配符。
# 多个来源用逗号分隔。
# ==============================================================================
CORS_ORIGINS=https://<请填写前端域名>,https://callback.misanduo.com


# ==============================================================================
# 18. 高级性能调优：抖音客服工作台（DOUYIN_WORKBENCH_*）
#
# 调用链：app/services/douyin_workbench_conversation_service.py:43-46（os.getenv + max() 下限保护）。
#
# 变量含义：
# - DOUYIN_WORKBENCH_CONVERSATION_EVENT_LIMIT：会话列表首次事件窗口（默认 2000，下限 100）。
#   用户可继续加载更早事件，最多扩至 20000；值越大，首次响应时间和内存占用越高。
# - DOUYIN_WORKBENCH_CONVERSATION_LOOKBACK_DAYS：账号未读统计回看天数（默认 7，下限 1）。
#   不再限制会话列表日期；值越大，未读统计扫描量越高。
# - DOUYIN_WORKBENCH_MESSAGE_LIMIT：工作台消息上限（默认 200，下限 20）。
# - DOUYIN_WORKBENCH_UNREAD_EVENT_LIMIT：未读事件上限（默认 5000，下限 100）。
#
# 通常保持默认值；只有压测或明确性能问题时修改。
# ==============================================================================
DOUYIN_WORKBENCH_CONVERSATION_EVENT_LIMIT=2000
DOUYIN_WORKBENCH_CONVERSATION_LOOKBACK_DAYS=7
DOUYIN_WORKBENCH_MESSAGE_LIMIT=200
DOUYIN_WORKBENCH_UNREAD_EVENT_LIMIT=5000


# ==============================================================================
# 19. 安全开关（旧链路门禁）
#
# 调用链：app/config.py:313-333。
# - LEGACY_WECHAT_DEBUG_ENDPOINTS_ENABLED：旧微信调试接口开关，production 始终关闭。
# - AUTO_WECHAT_ENABLE_LEGACY_AUTO_DETECT：旧 wechat_auto_detect_scheduler 开关。
#   0=禁用（默认，新主线用 19000 Local Agent）；1=恢复旧行为（仅供回退调试）。
#   production 保持 0，避免旧调度器在 9000 所在电脑直接操作微信与新链路冲突。
# ==============================================================================
LEGACY_WECHAT_DEBUG_ENDPOINTS_ENABLED=false
AUTO_WECHAT_ENABLE_LEGACY_AUTO_DETECT=0


# ==============================================================================
# 18. Phase 8 每日自动报表存储与调度
#
# 仅模板：不含真实 token/路径/客户配置。生产示例保持 scheduler=false，部署时显式开启。
# DAILY_REPORT_TIMEZONE 交给 zoneinfo 解析；DAILY_REPORT_SCHEDULE_LOCAL_TIME 只接受 HH:MM 00:00-23:59。
# ==============================================================================
DAILY_REPORT_STORAGE_DIR=./data/daily_reports
DAILY_REPORT_TIMEZONE=Asia/Shanghai
DAILY_REPORT_SCHEDULER_ENABLED=false
DAILY_REPORT_SCHEDULE_LOCAL_TIME=01:10

# Phase 8-B 日报附件投递（默认关闭，灰度 allowlist；不含真实 token/联系人）
DAILY_REPORT_ATTACHMENT_DELIVERY_ENABLED=false
DAILY_REPORT_ATTACHMENT_ALLOW_FULL_ROLLOUT=false
# 灰度 allowlist：逗号分隔销售 ID（如 12,34），空表示全关闭
DAILY_REPORT_ATTACHMENT_STAFF_ALLOWLIST_IDS=
DAILY_REPORT_ATTACHMENT_MAX_BYTES=20971520
DAILY_REPORT_ATTACHMENT_DOWNLOAD_TTL_SECONDS=120
DAILY_REPORT_ATTACHMENT_SEND_AUTH_TTL_SECONDS=15
DAILY_REPORT_ATTACHMENT_EXECUTION_LEASE_SECONDS=300
# production 必须 false；insecure HTTP 仅 LAN 首测且只允许 loopback/RFC1918
LOCAL_AGENT_ATTACHMENT_ALLOW_INSECURE_PRIVATE_HTTP=false
