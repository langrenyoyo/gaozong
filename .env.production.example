# auto_wechat 生产环境模板。
# 复制为 .env.production.local 后填写真实密钥；.local 文件禁止提交。
# 生产固定使用 PostgreSQL：一个实例、两个 database。
# 容器内数据库 host 使用 postgres，不能写本机回环地址。
# 前端不得持有 internal token，不得直连 Milvus。

# Runtime
APP_ENV=production
PYTHONUNBUFFERED=1

# Database
PG_USER=<production-user>
PG_PASSWORD=<production-secret>
PG_DB=auto_wechat
DATABASE_URL=postgresql+psycopg://<production-user>:<production-secret>@postgres:5432/auto_wechat
RAG_DATABASE_URL=postgresql+psycopg://<production-user>:<production-secret>@postgres:5432/xg_douyin_ai_cs
EXPECTED_DATABASE_NAME=auto_wechat
RAG_EXPECTED_DATABASE_NAME=xg_douyin_ai_cs
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=5000
RAG_DB_POOL_SIZE=20
RAG_DB_MAX_OVERFLOW=40
RAG_DB_POOL_TIMEOUT=30
RAG_DB_POOL_RECYCLE=1800
RAG_DB_STATEMENT_TIMEOUT_MS=5000

# NewCar authentication
NEWCAR_AUTH_ENABLED=true
NEWCAR_AUTH_MOCK_ENABLED=false
NEWCAR_AUTH_BASE_URL=https://<newcar-auth-host>
NEWCAR_AUTH_EXCHANGE_CODE_URL=
NEWCAR_AUTH_ME_URL=
NEWCAR_AUTH_LOGOUT_URL=
NEWCAR_AUTH_LOGIN_URL=https://<newcar-login-host>/login
NEWCAR_AUTH_SERVICE_TOKEN=<newcar-service-token>
NEWCAR_AUTH_TIMEOUT_SECONDS=5

# Douyin OpenAPI / webhook
DY_SECRET_KEY=<douyin-webhook-secret>
DY_GMP_SECRET_KEY=<douyin-openapi-secret>
DY_OPENAPI_BASE_URL=https://gmp.bytedanceapi.com
DY_OPENAPI_PREFIX=/ai_chat_agent_api/v1/openapi
DY_MAIN_ACCOUNT_ID=<douyin-main-account-id>
DY_ACCOUNT_NAME=<douyin-account-name>
DY_HTTP_TIMEOUT_SECONDS=20
DY_ALLOWED_DRIFT_SECONDS=300
DOUYIN_WEBHOOK_AUTH_REQUIRED=true
DOUYIN_RESOURCE_ALLOWED_HOSTS=<douyin-resource-hosts>
PUBLIC_BASE_URL=https://callback.misanduo.com
DY_AUTH_REDIRECT_URL=https://callback.misanduo.com/integrations/douyin/live-check/oauth-callback
DY_AUTH_REDIRECT_FRONTEND_URL=https://<frontend-host>
DY_AUTH_REDIRECT_ALLOWED_ORIGINS=https://<frontend-host>
DY_CALLBACK_URL=https://callback.misanduo.com/integrations/douyin/live-check/webhook-observe
DY_CALLBACK_EVENTS=im_receive_msg,im_send_msg,im_enter_direct_msg

# Internal security
XG_DOUYIN_AI_CS_BASE_URL=http://xg-douyin-ai-cs:9100
XG_DOUYIN_AI_CS_SERVICE_TOKEN=<internal-9100-token>
XG_DOUYIN_AI_CS_TIMEOUT_SECONDS=60
AUTO_WECHAT_9000_BASE_URL=http://auto-wechat-api:9000
COMPUTE_INTERNAL_TOKEN=<compute-internal-token>
COMPUTE_USAGE_TIMEOUT_SECONDS=20
LOCAL_AGENT_AUTH_REQUIRED=true
LOCAL_AGENT_TOKENS=<merchant-id>:<local-agent-token>
KNOWLEDGE_TRAINING_IP_WHITELIST=<trusted-admin-ip-or-cidr>
KNOWLEDGE_TRAINING_INTERNAL_TOKENS=<knowledge-training-token>
KNOWLEDGE_TRAINING_DEFAULT_TENANT_ID=xiaogao_system
KNOWLEDGE_TRAINING_DEFAULT_MERCHANT_ID=xiaogao_base
KNOWLEDGE_TRAINING_TRUST_PROXY_HEADERS=true
LEADS_INTERNAL_TOKEN=<leads-internal-token>

# Service URLs / CORS
CORS_ORIGINS=https://<frontend-host>,https://callback.misanduo.com
VITE_API_BASE_URL=/api
VITE_AUTO_WECHAT_API_BASE_URL=/api
VITE_DOUYIN_AI_CS_API_BASE_URL=/ai-cs-api
VITE_NEWCAR_AUTH_BASE_URL=https://<newcar-auth-host>
VITE_NEWCAR_LOGIN_URL=https://<newcar-login-host>/login
VITE_DEV_API_PROXY_TARGET=http://auto-wechat-api:9000
VITE_DEV_DOUYIN_AI_CS_PROXY_TARGET=http://xg-douyin-ai-cs:9100

# RAG / LLM essentials
RAG_VECTOR_BACKEND=sqlite
XG_DOUYIN_AI_LLM_BASE_URL=https://api.openai.com/v1
XG_DOUYIN_AI_LLM_API_KEY=<llm-api-key>
XG_DOUYIN_AI_LLM_CHAT_MODEL=gpt-4o-mini
XG_DOUYIN_AI_LLM_TIMEOUT_SECONDS=60
XG_DOUYIN_AI_LLM_TEMPERATURE=0.2
XG_DOUYIN_AI_EMBEDDING_ENABLED=false
XG_DOUYIN_AI_AGENT_RUNTIME_ENABLED=false

# Feature gates
DOUYIN_AUTO_REPLY_ENABLED=false
DOUYIN_AUTO_REPLY_REAL_SEND_ENABLED=false
DOUYIN_AUTO_REPLY_ALLOW_FULL_ROLLOUT=false
LEGACY_WECHAT_DEBUG_ENDPOINTS_ENABLED=false
AUTO_WECHAT_ENABLE_LEGACY_AUTO_DETECT=0
