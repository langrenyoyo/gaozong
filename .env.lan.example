# ==============================================================================
# 00. 文件用途与复制方式
#
# 本文件是 auto_wechat 办公室局域网联调模板（同事联调用）。
# 复制为 .env.lan.local 后按需修改；.local 文件禁止提交 Git。
#
# LAN 环境定调：
# - 环境身份：development（不是 production，不连生产数据库）。
# - 数据库：开发 SQLite（不连接宝塔 production PostgreSQL）。
# - 鉴权：真实 NewCar（mock 关闭，走 LAN 上的 NewCar 服务）。
# - 服务地址：局域网 IP（192.168.110.*）。
# - 向量数据库：外部开发 Milvus，使用独立 LAN/dev collection，禁止使用 production collection。
# - Local Agent：浏览器访问本机 127.0.0.1:19000（每台电脑自己的 Agent）。
#
# 复制命令：
#   cp .env.lan.example .env.lan.local
#
# 完整变量说明见 docs/config/ENV_VARIABLE_REFERENCE.md。
# ==============================================================================


# ==============================================================================
# 01. 当前环境身份
#
# APP_ENV=development：LAN 仍是开发环境，webhook 验签不强制。
# 读取点：app/config.py:223。
# ==============================================================================
APP_ENV=development
PYTHONUNBUFFERED=1


# ==============================================================================
# 02. 地址填写规则（LAN 专属，务必先读）
#
# LAN 联调最常见错误是地址角色混淆。填地址前先判断「谁访问谁」：
#
# - 浏览器访问局域网其他机器：填对方 LAN IP（如 http://192.168.110.113:5173）。
# - 容器访问同一 Compose 服务：填 Compose service name（如 http://auto-wechat-api:9000）。
# - 容器访问局域网其他机器：填对方 LAN IP（容器通过宿主机网络出去）。
# - 浏览器访问本机 Local Agent：填 127.0.0.1（浏览器自己电脑的 Agent）。
# - 不能用 localhost 访问另一台机器（localhost 只指自己）。
#
# LAN IP 变化时只改下方 LAN_* 段，其余地址引用这些变量。
# ==============================================================================
LAN_FRONTEND_HOST=192.168.110.113
LAN_API_HOST=192.168.110.113
LAN_AUTH_HOST=192.168.110.19


# ==============================================================================
# 03. 当前 LAN 地址清单（团队已确认值）
#
# 集中放一处，IP 变化时只改这里。其余配置引用本段语义。
#
# auto_wechat frontend：192.168.110.113:5173（Vite dev server）
# auto_wechat backend：192.168.110.113:9000（9000 主服务）
# 9100 AI 客服：192.168.110.113:9100（抖音AI客服独立服务）
# NewCar login：192.168.110.19:5174（NewCar 登录页）
# NewCar auth：192.168.110.19:8790（NewCar 认证服务）
# ==============================================================================


# ==============================================================================
# 04. 9000 主数据库（SQLite，开发库）
#
# 调用链同 development 第 02 节。
# LAN 用开发 SQLite，不连接宝塔 production PostgreSQL。
# 两个 .db 文件独立。相对路径相对于项目根目录。
# ==============================================================================
DATABASE_URL=sqlite:///./data/auto_wechat.db
RAG_DATABASE_URL=sqlite:///./apps/xg_douyin_ai_cs/data/xg_douyin_ai_cs.db


# ==============================================================================
# 05. 9000 SQLite 连接池（SQLALCHEMY_*）
#
# 调用链同 development 第 03 节。
# LAN 用 SQLite，配 SQLALCHEMY_*（只控制 SQLite engine，不影响 PG）。
# LAN 不配 DB_POOL_*（那是 PG 专用，见 production 第 04 节）。
# ==============================================================================
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_PRE_PING=true


# ==============================================================================
# 06. 外部 Milvus（向量后端，LAN 联调用）
#
# 调用链同 production 第 14 节。
# LAN 联调使用外部开发 Milvus，MILVUS_COLLECTION 必须是独立 LAN/dev collection。
#
# LAN 约束（安全底线）：
# - 不得使用 production collection（MILVUS_COLLECTION 不得与 prod 相同）。
# - 凭据应为开发凭据，不得使用 production Milvus 密码。
# - collection 名应带 dev/lan 标识（如 xg_douyin_lan）。
# - Embedding DIMENSIONS 必须与 MILVUS_DIMENSION 一致（本模板均 2048）。
# - 9100 容器必须能访问外部 Milvus（填容器可达的地址）。
# - LAN Milvus 不可达 → readiness 503，不回退 SQLite。
# ==============================================================================
RAG_VECTOR_BACKEND=milvus
MILVUS_URI=<请填写LAN开发Milvus连接地址>
MILVUS_USERNAME=<请填写LAN开发Milvus用户名>
MILVUS_PASSWORD=<请填写LAN开发Milvus密码>
MILVUS_DB_NAME=<请填写LAN开发Milvus数据库名>
MILVUS_COLLECTION=<请填写LAN开发Collection名>
MILVUS_DIMENSION=2048
MILVUS_TIMEOUT_SECONDS=5
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE
MILVUS_CONNECT_STRATEGY=orm


# ==============================================================================
# 07. NewCar 真实鉴权（LAN）
#
# 调用链同 production 第 06 节。LAN 走真实 NewCar（LAN_AUTH_HOST 上）。
# - NEWCAR_AUTH_ENABLED=true：启用真实校验。
# - NEWCAR_AUTH_MOCK_ENABLED=false：关闭 mock。
# - BASE_URL / LOGIN_URL 用 LAN AUTH HOST（192.168.110.19）。
# ==============================================================================
NEWCAR_AUTH_ENABLED=true
NEWCAR_AUTH_MOCK_ENABLED=false
NEWCAR_AUTH_BASE_URL=http://192.168.110.19:8790
NEWCAR_AUTH_EXCHANGE_CODE_URL=
NEWCAR_AUTH_ME_URL=
NEWCAR_AUTH_LOGOUT_URL=
NEWCAR_AUTH_LOGIN_URL=http://192.168.110.19:5174/login
NEWCAR_AUTH_SERVICE_TOKEN=
NEWCAR_AUTH_TIMEOUT_SECONDS=5


# ==============================================================================
# 08. 上游 douyinAPI（dev/lan 独占）
#
# 调用链同 development 第 06 节。LAN 用本地 douyinAPI demo。
# production 走 webhook 直收，不依赖此上游链路。
# ==============================================================================
DOUYIN_API_BASE_URL=http://127.0.0.1:8081
DOUYIN_API_TIMEOUT_SECONDS=10
DOUYIN_SYNC_DEFAULT_LIMIT=50


# ==============================================================================
# 09. 服务间与内部安全密钥
#
# 调用链同 production 第 07 节。
# - XG_DOUYIN_AI_CS_BASE_URL：容器间用 Compose service name。
# - AUTO_WECHAT_9000_BASE_URL：容器间用 Compose service name。
# - LOCAL_AGENT_TOKENS：LAN 用 demo 值。
# - KNOWLEDGE_TRAINING_IP_WHITELIST：LAN 放开局域网段。
# ==============================================================================
XG_DOUYIN_AI_CS_BASE_URL=http://xg-douyin-ai-cs:9100
XG_DOUYIN_AI_CS_SERVICE_TOKEN=
XG_DOUYIN_AI_CS_TIMEOUT_SECONDS=60
AUTO_WECHAT_9000_BASE_URL=http://auto-wechat-api:9000
COMPUTE_INTERNAL_TOKEN=
COMPUTE_USAGE_TIMEOUT_SECONDS=5
LOCAL_AGENT_AUTH_REQUIRED=false
LOCAL_AGENT_TOKENS=demo_merchant_001:local-agent-dev-token
KNOWLEDGE_TRAINING_IP_WHITELIST=127.0.0.1,::1,localhost,192.168.110.0/24
KNOWLEDGE_TRAINING_INTERNAL_TOKENS=
KNOWLEDGE_TRAINING_DEFAULT_TENANT_ID=xiaogao_system
KNOWLEDGE_TRAINING_DEFAULT_MERCHANT_ID=xiaogao_base
KNOWLEDGE_TRAINING_TRUST_PROXY_HEADERS=false


# ==============================================================================
# 10. 抖音开放平台与 OAuth（LAN 现场联调）
#
# 调用链同 production 第 08 节。LAN 用局域网 IP 地址现场联调。
# - DY_SECRET_KEY / DY_GMP_SECRET_KEY：LAN 现场联调时在 .local 填真实值。
# - DOUYIN_WEBHOOK_AUTH_REQUIRED=false：LAN 仍是 development，不强制验签。
# - PUBLIC_BASE_URL：LAN 用 http://LAN_API_HOST:9000。
# - 回跳/回调 URL 用 LAN_API_HOST（192.168.110.113）。
# - DY_AUTH_REDIRECT_ALLOWED_ORIGINS 含开发机主机名（DESKTOP-T0HA3GO）。
# ==============================================================================
DY_SECRET_KEY=
DY_GMP_SECRET_KEY=
DY_OPENAPI_BASE_URL=https://gmp.bytedanceapi.com
DY_OPENAPI_PREFIX=/ai_chat_agent_api/v1/openapi
DY_MAIN_ACCOUNT_ID=0
DY_ACCOUNT_NAME=
DY_HTTP_TIMEOUT_SECONDS=20
DY_ALLOWED_DRIFT_SECONDS=300
DY_OAUTH_STATE_TTL_SECONDS=900
DOUYIN_WEBHOOK_AUTH_REQUIRED=false
PUBLIC_BASE_URL=http://192.168.110.113:9000
DY_AUTH_REDIRECT_URL=http://192.168.110.113:9000/integrations/douyin/live-check/oauth-callback
DY_AUTH_REDIRECT_FRONTEND_URL=http://192.168.110.113:5173
DY_AUTH_REDIRECT_ALLOWED_ORIGINS=http://192.168.110.113:5173,http://DESKTOP-T0HA3GO:5173
DY_CALLBACK_URL=http://192.168.110.113:9000/integrations/douyin/live-check/webhook-observe
DY_CALLBACK_EVENTS=im_receive_msg,im_send_msg,im_enter_direct_msg


# ==============================================================================
# 11. 抖音 Live Check
#
# 调用链同 production 第 09 节。LAN 现场联调需要时在 .env.lan.local 开启。
# ==============================================================================
DY_LIVE_CHECK_ENABLED=false
DY_LIVE_CHECK_FORWARD_TO_FORMAL=false
DOUYIN_RESOURCE_ALLOWED_HOSTS=


# ==============================================================================
# 12. 抖音自动回复与白名单
#
# 调用链同 production 第 10 节。LAN 默认全关闭。
# ==============================================================================
DOUYIN_AUTO_REPLY_ENABLED=false
DOUYIN_AUTO_REPLY_REAL_SEND_ENABLED=false
DOUYIN_AUTO_REPLY_ALLOW_FULL_ROLLOUT=false
DOUYIN_AUTO_REPLY_ACCOUNT_WHITELIST=
DOUYIN_AUTO_REPLY_CUSTOMER_WHITELIST=
DOUYIN_AUTO_REPLY_CONVERSATION_WHITELIST=


# ==============================================================================
# 13. Leads 9202 内部服务
#
# 调用链同 production 第 11 节。LAN 默认关闭 internal webhook。
# ==============================================================================
LEADS_SERVICE_BASE_URL=http://127.0.0.1:9202
LEADS_INTERNAL_TOKEN=
LEADS_CLIENT_TIMEOUT_SECONDS=5
LEADS_WEBHOOK_INTERNAL_ENABLED=false
LEADS_WEBHOOK_FALLBACK_LOCAL=true


# ==============================================================================
# 14. 前端 Vite 配置（浏览器 + dev proxy）
#
# 读取点同 production 第 16 节。
# - VITE_*_BASE_URL：LAN 用反代路径 /api、/ai-cs-api。
# - VITE_LOCAL_WECHAT_AGENT_BASE_URL：127.0.0.1:19000（浏览器所在电脑本机 Agent）。
# - VITE_NEWCAR_AUTH_BASE_URL / LOGIN_URL：LAN AUTH HOST（192.168.110.19）。
# - VITE_DEV_*_PROXY_TARGET：容器间 Compose service name。
# - CORS_ORIGINS：含 LAN IP、开发机主机名、localhost。
# ==============================================================================
CORS_ORIGINS=http://192.168.110.113:5173,http://DESKTOP-T0HA3GO:5173,http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE_URL=/api
VITE_AUTO_WECHAT_API_BASE_URL=/api
VITE_DOUYIN_AI_CS_API_BASE_URL=/ai-cs-api
VITE_LOCAL_WECHAT_AGENT_BASE_URL=http://127.0.0.1:19000
VITE_NEWCAR_AUTH_BASE_URL=http://192.168.110.19:8790
VITE_NEWCAR_LOGIN_URL=http://192.168.110.19:5174/login
VITE_DEV_API_PROXY_TARGET=http://auto-wechat-api:9000
VITE_DEV_DOUYIN_AI_CS_PROXY_TARGET=http://xg-douyin-ai-cs:9100


# ==============================================================================
# 15. Local Agent（Python 直启，LAN 专用）
#
# 调用链同 development 第 12 节。
# AUTO_WECHAT_SERVER_URL 指向局域网 9000（192.168.110.113:9000），
# Agent 在销售/开发电脑本机直启，向 LAN 上的 9000 拉任务/回写/心跳。
# 这 7 个变量只进 dev/lan 模板，不进 production。
# ==============================================================================
LOCAL_AGENT_HOST=127.0.0.1
LOCAL_AGENT_PORT=19000
AUTO_WECHAT_SERVER_URL=http://192.168.110.113:9000
LOCAL_AGENT_LOG_FILE=logs/local_agent.log
AUTO_WECHAT_AGENT_CLIENT_ID=local-agent-default
AUTO_WECHAT_AGENT_NAME=小高AI微信助手
LOCAL_AGENT_TASK_POLL_INTERVAL_SECONDS=5


# ==============================================================================
# 16. 9100 LLM（对话模型）
#
# 调用链同 production 第 12 节。LAN API_KEY 留空或填开发 key。
# ==============================================================================
XG_DOUYIN_AI_LLM_BASE_URL=https://api.openai.com/v1
XG_DOUYIN_AI_LLM_API_KEY=
XG_DOUYIN_AI_LLM_CHAT_MODEL=gpt-4o-mini
XG_DOUYIN_AI_LLM_TIMEOUT_SECONDS=60
XG_DOUYIN_AI_LLM_TEMPERATURE=0.2
XG_DOUYIN_AI_AGENT_RUNTIME_ENABLED=false


# ==============================================================================
# 17. 9100 Embedding（火山方舟 Ark）
#
# 调用链同 production 第 13 节。
# LAN 联调真实 RAG 时在 .env.lan.local 设 ENABLED=true 并填开发 key。
# DIMENSIONS 必须与 MILVUS_DIMENSION 一致（本模板均 2048）。
# ==============================================================================
XG_DOUYIN_AI_EMBEDDING_ENABLED=false
XG_DOUYIN_AI_EMBEDDING_PROVIDER=ark
XG_DOUYIN_AI_EMBEDDING_API_KEY=
XG_DOUYIN_AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
XG_DOUYIN_AI_EMBEDDING_ENDPOINT=/embeddings/multimodal
XG_DOUYIN_AI_EMBEDDING_MODEL=doubao-embedding-vision-250615
XG_DOUYIN_AI_EMBEDDING_DIMENSIONS=2048
XG_DOUYIN_AI_EMBEDDING_ENCODING_FORMAT=float
XG_DOUYIN_AI_EMBEDDING_SPARSE_ENABLED=false
XG_DOUYIN_AI_EMBEDDING_TIMEOUT_SECONDS=120


# ==============================================================================
# 18. 高级性能调优：抖音客服工作台（DOUYIN_WORKBENCH_*）
#
# 调用链同 production 第 18 节。LAN 保持默认值。
# ==============================================================================
DOUYIN_WORKBENCH_CONVERSATION_EVENT_LIMIT=2000
DOUYIN_WORKBENCH_CONVERSATION_LOOKBACK_DAYS=7
DOUYIN_WORKBENCH_MESSAGE_LIMIT=200
DOUYIN_WORKBENCH_UNREAD_EVENT_LIMIT=5000


# ==============================================================================
# 19. 安全开关（旧链路门禁）
#
# 调用链同 production 第 19 节。LAN 保持关闭。
# ==============================================================================
LEGACY_WECHAT_DEBUG_ENDPOINTS_ENABLED=false
AUTO_WECHAT_ENABLE_LEGACY_AUTO_DETECT=0
