# ==============================================================================
# 00. 文件用途与复制方式
#
# 本文件是 auto_wechat 开发者单机开发模板。
# 复制为 .env.development.local 后按需修改；.local 文件禁止提交 Git。
#
# 开发环境定调：
# - 数据库：本地 SQLite（9000 + 9100 各一个 .db 文件）。
# - 鉴权：mock（NewCar 模拟身份，不连真实 NewCar）。
# - 地址：localhost / 127.0.0.1（单机开发）。
# - 向量后端：SQLite 向量副本（单机轻量开发，不连外部 Milvus）。
# - 禁止：production 密码、production collection、正式 token。
#
# 如需真实 NewCar 联调或局域网同事联调，改用 .env.lan.example。
# 完整变量说明见 docs/config/ENV_VARIABLE_REFERENCE.md。
#
# 复制命令：
#   cp .env.development.example .env.development.local
# ==============================================================================


# ==============================================================================
# 01. 当前环境身份
#
# APP_ENV=development：webhook 验签不强制（DOUYIN_WEBHOOK_AUTH_REQUIRED=false 生效）。
# 读取点：app/config.py:223。
# PYTHONUNBUFFERED=1：容器/终端日志不缓冲。
# ==============================================================================
APP_ENV=development
PYTHONUNBUFFERED=1


# ==============================================================================
# 02. 9000 主数据库（SQLite）
#
# 调用链：
#   DATABASE_URL → app/config.py → app/database.py create_database_engine() SQLite 分支
#   → SQLAlchemy create_engine(sqlite:///, connect_args={check_same_thread, timeout})
#
# 关键约束：
# - DATABASE_URL 指向 9000 SQLite 文件（相对路径相对于项目根目录）。
# - RAG_DATABASE_URL 指向 9100 独立 SQLite 文件，必须与 DATABASE_URL 分开。
# - 两个 .db 文件独立，不共享表结构。
# - production 不使用这些 SQLite URL（production 用 PostgreSQL）。
# - 旧变量 XG_DOUYIN_AI_CS_DB_PATH 已废弃，RAG_DATABASE_URL 优先（见参考文档第 4 节）。
# ==============================================================================
DATABASE_URL=sqlite:///./data/auto_wechat.db
RAG_DATABASE_URL=sqlite:///./apps/xg_douyin_ai_cs/data/xg_douyin_ai_cs.db


# ==============================================================================
# 03. 9000 SQLite 连接池（SQLALCHEMY_*）
#
# 调用链（以代码读取点为准）：
#   SQLALCHEMY_* → app/database.py 顶部读取（line 29-37）
#   → create_database_engine() SQLite 分支（line 205-215）
#   → SQLAlchemy create_engine(sqlite, pool_size=SQLALCHEMY_POOL_SIZE, ...)
#   → 9000 SQLite engine（dev 实际生效）
#
# 变量含义：
# - SQLALCHEMY_POOL_SIZE：SQLite 常驻连接数（默认 10）。
# - SQLALCHEMY_MAX_OVERFLOW：池满后临时溢出连接数（默认 20）。
# - SQLALCHEMY_POOL_TIMEOUT：等待可用连接秒数（默认 30）。
# - SQLALCHEMY_POOL_PRE_PING：连接预检（默认 true）。
#
# 注意：SQLALCHEMY_* 只控制 SQLite engine，不影响 PostgreSQL。
# dev 不配 DB_POOL_*（那是 PG 专用，见 .env.production.example 第 04 节）。
# SQLite 路径不进连接池回收/语句超时（那些是 PG 专属）。
# ==============================================================================
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_PRE_PING=true


# ==============================================================================
# 04. 向量后端（SQLite 向量副本）
#
# 调用链：RAG_VECTOR_BACKEND → apps/xg_douyin_ai_cs/config.py settings.rag_vector_backend
# → vector_store 工厂选择 SQLite 或 Milvus backend。
#
# dev 默认 sqlite 向量副本，便于单机轻量开发（无需外部 Milvus）。
# production 固定 milvus（见 .env.production.example 第 14 节）。
# 如需在 dev 测试 Milvus，可改 .env.development.local 设 milvus + MILVUS_*（见参考文档）。
# ==============================================================================
RAG_VECTOR_BACKEND=sqlite


# ==============================================================================
# 05. Mock 鉴权（本地开发）
#
# 调用链：app/config.py:256-264。
# - NEWCAR_AUTH_ENABLED=false：不拦截业务接口（本地开发友好）。
# - NEWCAR_AUTH_MOCK_ENABLED=true：mock 返回开发身份（固定商户 + 既定权限）。
#
# mock 身份的商户边界和权限用途由代码既定（不在此展开权限字典）。
# dev 不填真实 NewCar 地址；如需真实联调改用 .env.lan.example。
# ==============================================================================
NEWCAR_AUTH_ENABLED=false
NEWCAR_AUTH_MOCK_ENABLED=true
NEWCAR_AUTH_BASE_URL=http://127.0.0.1:8790
NEWCAR_AUTH_EXCHANGE_CODE_URL=
NEWCAR_AUTH_ME_URL=
NEWCAR_AUTH_LOGOUT_URL=
NEWCAR_AUTH_LOGIN_URL=http://127.0.0.1:5174/login
NEWCAR_AUTH_SERVICE_TOKEN=
NEWCAR_AUTH_TIMEOUT_SECONDS=5


# ==============================================================================
# 06. 上游 douyinAPI（dev/lan 独占）
#
# 调用链：app/config.py:217-219。
# - DOUYIN_API_BASE_URL：旧 douyinAPI 上游同步链路地址（本地 demo，127.0.0.1:8081）。
# - DOUYIN_API_TIMEOUT_SECONDS：上游请求超时秒（默认 10）。
# - DOUYIN_SYNC_DEFAULT_LIMIT：同步拉取线索上限（默认 50）。
#
# 注意：production 走 webhook 直收，不依赖 douyinAPI 上游同步链路，这三个变量不进 prod 模板。
# ==============================================================================
DOUYIN_API_BASE_URL=http://127.0.0.1:8081
DOUYIN_API_TIMEOUT_SECONDS=10
DOUYIN_SYNC_DEFAULT_LIMIT=50


# ==============================================================================
# 07. 服务间与内部安全密钥
#
# 调用链同 production 第 07 节，但 dev 全部留空或用本地值。
# - XG_DOUYIN_AI_CS_BASE_URL：dev 留空（9000 默认 localhost:9100）。
# - AUTO_WECHAT_9000_BASE_URL：dev 留空（9100 不上报算力）。
# - COMPUTE_INTERNAL_TOKEN：dev 留空（内部接口开发放行）。
# - LOCAL_AGENT_TOKENS：dev 用 demo 值。
# - KNOWLEDGE_TRAINING_*：dev 默认本地白名单。
# ==============================================================================
XG_DOUYIN_AI_CS_BASE_URL=
XG_DOUYIN_AI_CS_SERVICE_TOKEN=
XG_DOUYIN_AI_CS_TIMEOUT_SECONDS=60
AUTO_WECHAT_9000_BASE_URL=
COMPUTE_INTERNAL_TOKEN=
COMPUTE_USAGE_TIMEOUT_SECONDS=5
LOCAL_AGENT_AUTH_REQUIRED=false
LOCAL_AGENT_TOKENS=demo_merchant_001:local-agent-dev-token
KNOWLEDGE_TRAINING_IP_WHITELIST=127.0.0.1,::1,localhost
KNOWLEDGE_TRAINING_INTERNAL_TOKENS=
KNOWLEDGE_TRAINING_DEFAULT_TENANT_ID=xiaogao_system
KNOWLEDGE_TRAINING_DEFAULT_MERCHANT_ID=xiaogao_base
KNOWLEDGE_TRAINING_TRUST_PROXY_HEADERS=false


# ==============================================================================
# 08. 抖音开放平台与 OAuth（dev 本地联调）
#
# 调用链同 production 第 08 节。dev 用 localhost 地址本地联调。
# - DY_SECRET_KEY / DY_GMP_SECRET_KEY：dev 留空（本地不验签）。
# - DOUYIN_WEBHOOK_AUTH_REQUIRED=false：dev 不强制验签。
# - PUBLIC_BASE_URL：dev 用 http://127.0.0.1:9000。
# - 所有回跳/回调 URL 用 localhost。
# ==============================================================================
DY_SECRET_KEY=
DY_GMP_SECRET_KEY=
DY_OPENAPI_BASE_URL=https://gmp.bytedanceapi.com
DY_OPENAPI_PREFIX=/ai_chat_agent_api/v1/openapi
DY_MAIN_ACCOUNT_ID=0
DY_ACCOUNT_NAME=
DY_HTTP_TIMEOUT_SECONDS=20
DY_ALLOWED_DRIFT_SECONDS=300
DY_OAUTH_STATE_TTL_SECONDS=900
DOUYIN_WEBHOOK_AUTH_REQUIRED=false
PUBLIC_BASE_URL=http://127.0.0.1:9000
DY_AUTH_REDIRECT_URL=http://127.0.0.1:9000/integrations/douyin/live-check/oauth-callback
DY_AUTH_REDIRECT_FRONTEND_URL=http://127.0.0.1:5173
DY_AUTH_REDIRECT_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DY_CALLBACK_URL=http://127.0.0.1:9000/integrations/douyin/live-check/webhook-observe
DY_CALLBACK_EVENTS=im_receive_msg,im_send_msg,im_enter_direct_msg


# ==============================================================================
# 09. 抖音 Live Check
#
# 调用链同 production 第 09 节。dev 默认关闭。
# DOUYIN_RESOURCE_ALLOWED_HOSTS 留空走代码默认拦截。
# ==============================================================================
DY_LIVE_CHECK_ENABLED=false
DY_LIVE_CHECK_FORWARD_TO_FORMAL=false
DOUYIN_RESOURCE_ALLOWED_HOSTS=


# ==============================================================================
# 10. 抖音自动回复与白名单
#
# 调用链同 production 第 10 节。dev 默认全关闭。
# ==============================================================================
DOUYIN_AUTO_REPLY_ENABLED=false
DOUYIN_AUTO_REPLY_REAL_SEND_ENABLED=false
DOUYIN_AUTO_REPLY_ALLOW_FULL_ROLLOUT=false
DOUYIN_AUTO_REPLY_ACCOUNT_WHITELIST=
DOUYIN_AUTO_REPLY_CUSTOMER_WHITELIST=
DOUYIN_AUTO_REPLY_CONVERSATION_WHITELIST=


# ==============================================================================
# 11. Leads 9202 内部服务
#
# 调用链同 production 第 11 节。dev 默认关闭 internal webhook，走本地 fallback。
# ==============================================================================
LEADS_SERVICE_BASE_URL=http://127.0.0.1:9202
LEADS_INTERNAL_TOKEN=
LEADS_CLIENT_TIMEOUT_SECONDS=5
LEADS_WEBHOOK_INTERNAL_ENABLED=false
LEADS_WEBHOOK_FALLBACK_LOCAL=true


# ==============================================================================
# 12. Local Agent（Python 直启，dev 专用）
#
# 调用链：
# - LOCAL_AGENT_HOST/PORT → app/local_agent_exe_entry.py build_parser()（line 80-81），
#   也作 --host/--port 默认值；Python 直启 app/local_agent_main.py 时由命令行传入。
# - AUTO_WECHAT_SERVER_URL → exe_entry.py line 84，Agent 主动请求 9000 的地址（拉任务/回写/心跳）。
# - LOCAL_AGENT_LOG_FILE → exe_entry.py line 87，日志文件路径（相对路径相对于运行目录）。
# - AUTO_WECHAT_AGENT_CLIENT_ID/NAME → local_agent_main.py line 208-209，心跳上报身份。
# - LOCAL_AGENT_TASK_POLL_INTERVAL_SECONDS → local_agent_main.py line 1061，任务轮询间隔秒。
#
# dev 用途：本机直接 python app/local_agent_main.py 启动 Agent 联调。
# exe 打包构建脚本会覆盖这些值（打包时内置）；Python 直启时需要。
#
# 注意：这 7 个变量只进 dev/lan 模板，不进 production（宝塔不跑 Agent）。
# token 在 LOCAL_AGENT_TOKENS（第 07 节）配置，与 9000 双向校验。
# ==============================================================================
LOCAL_AGENT_HOST=127.0.0.1
LOCAL_AGENT_PORT=19000
AUTO_WECHAT_SERVER_URL=http://127.0.0.1:9000
LOCAL_AGENT_LOG_FILE=logs/local_agent.log
AUTO_WECHAT_AGENT_CLIENT_ID=local-agent-default
AUTO_WECHAT_AGENT_NAME=小高AI微信助手
LOCAL_AGENT_TASK_POLL_INTERVAL_SECONDS=5


# ==============================================================================
# 13. 前端 Vite 配置（浏览器 + dev proxy）
#
# 读取点同 production 第 16 节。
# dev 用 localhost 地址；VITE_DEV_*_PROXY_TARGET 用 Compose service name（容器内 dev）。
# VITE_LOCAL_WECHAT_AGENT_BASE_URL 指向开发者本机 Agent（127.0.0.1:19000）。
# ==============================================================================
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE_URL=/api
VITE_AUTO_WECHAT_API_BASE_URL=/api
VITE_DOUYIN_AI_CS_API_BASE_URL=/ai-cs-api
VITE_LOCAL_WECHAT_AGENT_BASE_URL=http://127.0.0.1:19000
VITE_NEWCAR_AUTH_BASE_URL=http://127.0.0.1:8790
VITE_NEWCAR_LOGIN_URL=http://127.0.0.1:5174/login
VITE_DEV_API_PROXY_TARGET=http://auto-wechat-api:9000
VITE_DEV_DOUYIN_AI_CS_PROXY_TARGET=http://xg-douyin-ai-cs:9100


# ==============================================================================
# 14. 9100 LLM（对话模型）
#
# 调用链同 production 第 12 节。dev API_KEY 留空（本地不调真实 LLM 或用个人 key）。
# ==============================================================================
XG_DOUYIN_AI_LLM_BASE_URL=https://api.openai.com/v1
XG_DOUYIN_AI_LLM_API_KEY=
XG_DOUYIN_AI_LLM_CHAT_MODEL=gpt-4o-mini
XG_DOUYIN_AI_LLM_TIMEOUT_SECONDS=30
XG_DOUYIN_AI_LLM_TEMPERATURE=0.2
XG_DOUYIN_AI_AGENT_RUNTIME_ENABLED=false


# ==============================================================================
# 15. 9100 Embedding（火山方舟 Ark）
#
# 调用链同 production 第 13 节。
# dev ENABLED=false 走本地 mock_embedding（零费用、零外部调用）。
# 需测试真实 Ark embedding 时在 .env.development.local 设 ENABLED=true 并填开发 key。
# DIMENSIONS 必须与向量库维度一致（dev SQLite 向量副本也按此维度建表）。
# ==============================================================================
XG_DOUYIN_AI_EMBEDDING_ENABLED=false
XG_DOUYIN_AI_EMBEDDING_PROVIDER=ark
XG_DOUYIN_AI_EMBEDDING_API_KEY=
XG_DOUYIN_AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
XG_DOUYIN_AI_EMBEDDING_ENDPOINT=/embeddings/multimodal
XG_DOUYIN_AI_EMBEDDING_MODEL=doubao-embedding-vision-250615
XG_DOUYIN_AI_EMBEDDING_DIMENSIONS=2048
XG_DOUYIN_AI_EMBEDDING_ENCODING_FORMAT=float
XG_DOUYIN_AI_EMBEDDING_SPARSE_ENABLED=false
XG_DOUYIN_AI_EMBEDDING_TIMEOUT_SECONDS=120


# ==============================================================================
# 16. 高级性能调优：抖音客服工作台（DOUYIN_WORKBENCH_*）
#
# 调用链同 production 第 18 节。dev 保持默认值。
# ==============================================================================
DOUYIN_WORKBENCH_CONVERSATION_EVENT_LIMIT=2000
DOUYIN_WORKBENCH_CONVERSATION_LOOKBACK_DAYS=7
DOUYIN_WORKBENCH_MESSAGE_LIMIT=200
DOUYIN_WORKBENCH_UNREAD_EVENT_LIMIT=5000


# ==============================================================================
# 17. 安全开关（旧链路门禁）
#
# 调用链同 production 第 19 节。dev 保持关闭。
# ==============================================================================
LEGACY_WECHAT_DEBUG_ENDPOINTS_ENABLED=false
AUTO_WECHAT_ENABLE_LEGACY_AUTO_DETECT=0
