# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/

# Virtual environments and packaging metadata
.venv/
venv/
*.egg-info/

# Environment files
.env
.env.local
.env.staging
.env.*.local
.env.development.local
.env.lan.local
.env.production.local
.env.staging.local
!.env.production.example
!.env.development.example
!.env.lan.example

# Build artifacts and local backups
build/
dist/
dist_backup_*/
backups/
*.spec
!local_agent.spec

# Runtime data and logs
data/
logs/
*.log
@AutomationLog.txt

# xg_douyin_ai_cs local runtime data
apps/xg_douyin_ai_cs/data/*.db
apps/xg_douyin_ai_cs/data/*.db-journal
apps/xg_douyin_ai_cs/data/*.db-wal
apps/xg_douyin_ai_cs/data/*.db-shm
