# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/

# Virtual environments and packaging metadata
.venv/
venv/
*.egg-info/

# Environment files
.env
.env.*
!.env.example

# Build artifacts and local backups
build/
dist/
dist_backup_*/
*.spec
!local_agent.spec

# Runtime data and logs
data/
logs/
*.log
@AutomationLog.txt

# xg_douyin_ai_cs local runtime data
apps/xg_douyin_ai_cs/data/*.db
apps/xg_douyin_ai_cs/data/*.db-journal
apps/xg_douyin_ai_cs/data/*.db-wal
apps/xg_douyin_ai_cs/data/*.db-shm
apps/xg_douyin_ai_cs/data/*.sqlite
apps/xg_douyin_ai_cs/data/*.sqlite3

# Generated local agent build info
app/local_agent_build_info.py

# OCR model weights
resources/easyocr_models/*.pth
resources/easyocr_models/*.pt
resources/easyocr_models/*.onnx

# Local tool configuration
.vscode/
.claude/settings.local.json
CLAUDE.md

# Test/debug temporary files
test_cors_leads.json
test_wechat_debug.json

# Frontend（React/Vite 构建产物与缓存）
node_modules/
.vite/
frontend/dist/
frontend/.vite/

# TypeScript 声明产物（tsc -b / emitDeclarationOnly 生成，不应提交）
frontend/*.d.ts
frontend/tsconfig.tsbuildinfo

# Docker 本地开发运行数据（容器 SQLite 持久化，不应提交）
docker-data/
