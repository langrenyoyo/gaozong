# staging 环境变量模板（P3-E-9100-STAGING-ENV-BOOTSTRAP-1）
#
# 使用方式：复制为 .env.staging，只在 .env.staging 填真实密钥。
# .env.staging 已被 .gitignore 排除（.env* 且非 .example），禁止提交。
#
# staging 硬约束：
# - 独立 compose project（auto_wechat_staging），独立 volume（docker-data-staging/），独立端口（29000/29100/5180/25432）。
# - database 带 _staging 后缀（auto_wechat_staging / xg_douyin_ai_cs_staging），与 dev/生产双重隔离。
# - 禁止 SQLite metadata fallback（RAG_DATABASE_URL 必须指向 PG；XG_DOUYIN_AI_CS_DB_PATH 留空）。
# - 容器内 host 用 compose service name（postgres），不用 localhost。
# - 禁止填 production URL / 真实生产密码；真实密码只写进本地 .env.staging。

APP_ENV=staging

# ---------- PostgreSQL 容器（staging 独立实例）----------
# postgres 镜像 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB（compose 用 ${PG_USER}/${PG_PASSWORD}/${PG_DB} 组装）。
# staging 专用 role 与密码（非生产）；本地 .env.staging 填强密码。
PG_USER=auto_wechat_staging
PG_PASSWORD=change_me_staging_strong_password
PG_DB=auto_wechat_staging

# ---------- readiness 预期 database 名（支持隔离环境覆盖）----------
# 9000 readiness 校验 current_database() == EXPECTED_DATABASE_NAME。
# 9100 readiness 校验 current_database() == RAG_EXPECTED_DATABASE_NAME。
# 默认 auto_wechat / xg_douyin_ai_cs（dev/生产）；staging 用带后缀名避免 WRONG_DATABASE。
EXPECTED_DATABASE_NAME=auto_wechat_staging
RAG_EXPECTED_DATABASE_NAME=xg_douyin_ai_cs_staging

# ---------- 向量后端（本轮 staging 口径）----------
# sqlite：检索直接读 PG metadata chunks.embedding_json + Python cosine（无独立向量库/文件）。
# 不依赖 Milvus；staging 单实例；独立 PG volume 即满足隔离（sqlite 向量模式无独立向量文件）。
# 后续若切 milvus，须独立审批窗口（见 Runbook 34.11），不在本轮。
RAG_VECTOR_BACKEND=sqlite

# 留空：RAG_DATABASE_URL 优先，显式禁用 SQLite metadata fallback。
XG_DOUYIN_AI_CS_DB_PATH=

# 注：DATABASE_URL 与 RAG_DATABASE_URL 由 docker-compose.staging.yml 用
# ${PG_USER}/${PG_PASSWORD}/${PG_DB} + 固定 xg_douyin_ai_cs_staging 组装，
# 不在此重复，避免双源不一致。
