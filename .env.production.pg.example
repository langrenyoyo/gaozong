# 生产 PostgreSQL 切换环境变量模板（P3-E-9100-PRODUCTION-RELEASE-PACKAGE-1）
#
# 使用方式：在宝塔生产机复制为 .env（或合并进现有 .env），只在生产机 .env 填真实密钥。
# .env 已被 .gitignore 排除（.env* 且非 .example），禁止提交真实密码。
#
# 生产硬约束（首次切换固定口径）：
# - 9000 主业务库 + 9100 RAG metadata 库 = 一个 PG 实例两个 database（方案 A）
# - 容器内连接 PostgreSQL 用 service name `postgres`，不用 localhost
# - 两个 DATABASE_URL 指向不同 database（9000=主库，9100=xg_douyin_ai_cs）
# - RAG_VECTOR_BACKEND=sqlite（向量副本保留，metadata 真源 = PG）
# - XG_DOUYIN_AI_CS_DB_PATH 仅作向量副本或回滚用途，不作为 metadata 真源
# - 已有 PG volume 时 init-prod/010 不会自动重跑，第二库需用 ensure_databases 脚本显式创建
# - 禁止填本地/dev/staging 密码；真实生产密码只写进生产机 .env

APP_ENV=production

# ---------- PostgreSQL 容器 ----------
# postgres 镜像 POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB（compose 用 ${PG_USER}/${PG_PASSWORD}/${PG_DB} 组装）。
# 生产强密码由密码 Owner Waston 分发，仅写生产机 .env。
PG_USER=<production-user>
PG_PASSWORD=<production-secret>
PG_DB=<9000-production-database>

# ---------- 显式 DATABASE_URL（两库不同）----------
# compose environment 也会组装，但 .env 显式写入便于审计 + cutover 脚本读取。
# host 用 `postgres`（compose service name），不用 localhost。
DATABASE_URL=postgresql+psycopg://<user>:<password>@postgres:5432/<9000-database>
RAG_DATABASE_URL=postgresql+psycopg://<user>:<password>@postgres:5432/<9100-database>

# ---------- readiness 预期 database 名 ----------
# 9000 readiness 校验 current_database() == EXPECTED_DATABASE_NAME。
# 9100 readiness 校验 current_database() == RAG_EXPECTED_DATABASE_NAME。
# 两库必须不同（preflight 强制校验）。
EXPECTED_DATABASE_NAME=<9000-database>
RAG_EXPECTED_DATABASE_NAME=xg_douyin_ai_cs

# ---------- 向量后端（首次切换固定口径）----------
# sqlite：检索直接读 PG metadata chunks.embedding_json + Python cosine（无独立向量库）。
# 不依赖 Milvus；9100 单实例。后续切 Milvus 须独立审批窗口，不在本轮。
RAG_VECTOR_BACKEND=sqlite

# 仅作向量副本或回滚用途；metadata 真源是 RAG_DATABASE_URL 指向的 PG database。
# 切换 PG 后此 SQLite 不再作为 metadata 写入目标（sqlite_freeze_check 校验其不再增长）。
# 留空则禁用 SQLite metadata fallback（推荐）。
XG_DOUYIN_AI_CS_DB_PATH=

# ---------- 其他生产必需变量（从现有 .env 继承，此处仅列出 PG 切换相关校验项）----------
# SECRET_KEY / DY_SECRET_KEY / COMPUTE_INTERNAL_TOKEN / NEWCAR_* 等
# 不在本模板列出（由生产机现有 .env 提供，不随 PG 切换变更）。
